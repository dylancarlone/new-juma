---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Media from "@/components/Media.astro";
import CTABanner from "@/components/sections/CTABanner.astro";
import PostCard from "@/components/cards/PostCard.astro";
import { getAllPosts, postPath, slugifyTag } from "@/lib/content";

export async function getStaticPaths() {
  const posts = await getCollection("post");
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, publishDate, updatedDate, author, categories, heroImage, heroImageAlt, excerpt } = entry.data;

const dateStr = publishDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
const all = await getAllPosts();
const related = all.filter((p) => p.id !== entry.id).slice(0, 3);
---

<BaseLayout title={title} description={excerpt} image={heroImage ? `/media/${heroImage}` : undefined} type="article" publishedTime={publishDate}>
  <article>
    <header class="border-b border-navy-100 bg-cream/50">
      <Container size="narrow" class="py-12 md:py-16">
        <div class="flex flex-wrap items-center gap-3 text-xs">
          {categories.map((c) => (
            <a href={`/news/category/${slugifyTag(c)}/`} class="font-heading font-bold uppercase tracking-wide text-brand-600 hover:underline">{c}</a>
          ))}
          <time datetime={publishDate.toISOString()} class="text-warmgray">{dateStr}</time>
        </div>
        <h1 class="mt-4 text-3xl md:text-5xl">{title}</h1>
        <p class="mt-4 text-sm text-warmgray">By {author === "Juma" ? "the Juma Ventures team" : author}</p>
      </Container>
    </header>

    {
      heroImage && (
        <div class="bg-cream/50">
          <Container size="narrow" class="pb-2">
            <Media src={heroImage} alt={heroImageAlt ?? title} class="w-full rounded-2xl shadow-[var(--shadow-card)]" loading="eager" />
          </Container>
        </div>
      )
    }

    <Container size="narrow" class="py-12">
      <Content />
      {updatedDate && <p class="mt-10 border-t border-navy-100 pt-4 text-sm text-warmgray">Last updated {updatedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}.</p>}
      <div class="mt-10">
        <a href="/news/" class="font-semibold text-brand-600 hover:underline">← Back to all news</a>
      </div>
    </Container>
  </article>

  {
    related.length > 0 && (
      <section class="border-t border-navy-100 bg-cream/40">
        <Container class="py-14">
          <h2 class="mb-8 text-2xl md:text-3xl">More stories</h2>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((p) => (
              <PostCard
                href={postPath(p)}
                title={p.data.title}
                excerpt={p.data.excerpt}
                date={p.data.publishDate}
                image={p.data.heroImage}
                imageAlt={p.data.heroImageAlt}
                categories={p.data.categories}
              />
            ))}
          </div>
        </Container>
      </section>
    )
  }

  <CTABanner />
</BaseLayout>
