---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import PageHeader from "@/components/sections/PageHeader.astro";
import PostCard from "@/components/cards/PostCard.astro";
import { getFeedPosts, getCategories, postPath } from "@/lib/content";

const PAGE_SIZE = 12;
const posts = await getFeedPosts();
const categories = await getCategories();
const pageItems = posts.slice(0, PAGE_SIZE);
const totalPages = Math.ceil(posts.length / PAGE_SIZE);
---

<BaseLayout title="News" description="Stories, updates, and impact from Juma Ventures and the youth we serve.">
  <PageHeader eyebrow="Juma News" title="Stories & Updates" description="Youth journeys, program milestones, and news from across our four communities." />

  <Container class="py-12 md:py-16">
    {
      categories.length > 0 && (
        <div class="mb-10 flex flex-wrap gap-2">
          <span class="rounded-full bg-navy-900 px-4 py-1.5 text-sm font-semibold text-white">All</span>
          {categories.map((c) => (
            <a href={`/news/category/${c.slug}/`} class="rounded-full border border-navy-200 px-4 py-1.5 text-sm font-medium text-navy-700 transition hover:border-brand-400 hover:text-brand-600">
              {c.name} <span class="text-warmgray">({c.count})</span>
            </a>
          ))}
        </div>
      )
    }

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        pageItems.map((p) => (
          <PostCard
            href={postPath(p)}
            title={p.data.title}
            excerpt={p.data.excerpt}
            date={p.data.publishDate}
            image={p.data.heroImage}
            imageAlt={p.data.heroImageAlt}
            categories={p.data.categories}
          />
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <nav class="mt-12 flex items-center justify-center gap-4" aria-label="Pagination">
          <span class="text-sm font-semibold text-warmgray">Page 1 of {totalPages}</span>
          <a href="/news/page/2/" class="rounded-full bg-navy-900 px-6 py-2.5 font-heading text-sm font-bold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-navy-700 hover:shadow-[var(--shadow-lift)]">Next →</a>
        </nav>
      )
    }
  </Container>
</BaseLayout>
