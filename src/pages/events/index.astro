---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Hero from "@/components/sections/Hero.astro";
import Button from "@/components/ui/Button.astro";
---

<BaseLayout title="Events" description="Join Juma Ventures at our signature events, including the Paths to Possibility gala.">
  <Hero
    eyebrow="Events"
    heading="Paths to Possibility"
    subheading="Each year, our community comes together to celebrate the achievements of Juma youth and to invest in the next generation of leaders."
    align="center"
  />
  <Container size="narrow" class="py-16 text-center">
    <div class="rounded-[var(--radius-card)] border border-navy-100 bg-cream/50 p-10">
      <h2 class="text-2xl md:text-3xl">No upcoming events right now</h2>
      <p class="mx-auto mt-3 max-w-lg text-ink-soft">
        We're planning our next gathering. Subscribe to our newsletter to be the first to know about the next Paths to Possibility gala and other events.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <Button href="/newsletter/" variant="brand" size="lg">Join the Newsletter</Button>
        <Button href="/donate/" variant="outline" size="lg">Donate</Button>
      </div>
    </div>
  </Container>
</BaseLayout>
