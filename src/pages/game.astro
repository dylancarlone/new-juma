---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Button from "@/components/ui/Button.astro";
---

<BaseLayout
  title="Juma: Concourse Rush — A Stadium Doom-Style Run"
  description="Play Juma: Concourse Rush — a first-person, Doom-style stadium game. Work the concourse at four real Juma venues, serve hangry fans, earn tips, build money skills, and clock out a hero."
>
  <!-- Compact hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-800 text-white">
    <div class="absolute inset-0 bg-dots-light opacity-40" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-brand-500/15 blur-[100px]" aria-hidden="true"></div>
    <Container class="relative py-14 text-center md:py-20">
      <p class="eyebrow eyebrow-center justify-center text-gold">Move · Serve · Earn · Clock Out</p>
      <h1 class="mt-3 text-4xl text-white md:text-6xl">Juma: <span class="mark-brand">Concourse Rush</span></h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-navy-100">
        A first-person, Doom-style romp built on Juma's real model. Roam the concourse at four real venues,
        serve the hangry crowd before they overwhelm you, rack up tips — and clock out a hero.
      </p>
    </Container>
  </section>

  <!-- Game -->
  <section class="relative overflow-hidden bg-cream">
    <div class="absolute inset-0 bg-dots-dark opacity-50" aria-hidden="true"></div>
    <Container size="wide" class="relative py-10 md:py-16">
      <div
        id="gameday"
        class="relative mx-auto max-w-5xl select-none overflow-hidden rounded-[var(--radius-card)] bg-navy-950 text-white shadow-[var(--shadow-lift)] ring-1 ring-navy-100"
      >
        <!-- STAGE: canvas + overlays (title + pause live on top of the canvas) -->
        <div id="g-stage" class="relative">
          <canvas id="g-canvas" class="block w-full touch-none" width="960" height="620" aria-label="Juma Concourse Rush playfield"></canvas>

          <!-- Title overlay -->
          <div id="g-title-overlay" class="absolute inset-0 flex flex-col items-center justify-center bg-gradient-to-t from-navy-950/85 via-navy-950/40 to-navy-950/20 px-6 text-center">
            <p class="eyebrow eyebrow-center justify-center text-gold">Juma presents</p>
            <h2 class="mt-2 font-heading text-4xl font-extrabold tracking-tight text-white drop-shadow-lg md:text-6xl">CONCOURSE RUSH</h2>
            <p class="mx-auto mt-3 max-w-md text-sm text-navy-100 md:text-base">
              You're working the stand. Hangry fans are closing in from every aisle — serve them fast, keep your cool, and find the Clock-Out gate.
            </p>
            <p id="g-best" class="mt-3 hidden font-heading text-xs font-bold uppercase tracking-widest text-gold md:text-sm"></p>
            <div class="mt-6 flex flex-wrap justify-center gap-3">
              <button id="g-start" class="rounded-full bg-brand-500 px-8 py-3.5 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-600 md:px-10 md:py-4">▶ Start Your Shift</button>
              <button id="g-howto-btn" class="rounded-full border-2 border-white/70 bg-navy-950/40 px-8 py-3.5 font-heading text-sm font-bold uppercase tracking-wider text-white backdrop-blur transition-all duration-300 hover:-translate-y-0.5 hover:bg-white hover:text-navy-900 md:px-10 md:py-4">How to Play</button>
            </div>
          </div>

          <!-- Pause overlay -->
          <div id="g-pause-overlay" class="absolute inset-0 z-20 hidden flex-col items-center justify-center gap-5 bg-navy-950/90 backdrop-blur-sm">
            <p class="font-heading text-3xl font-extrabold text-white">Paused</p>
            <button id="g-resume" class="rounded-full bg-brand-500 px-9 py-3.5 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition hover:bg-brand-600">Resume</button>
          </div>
        </div>

        <!-- In-game controls (visible during play) -->
        <div id="g-controls" class="hidden items-center gap-2 border-t border-white/10 bg-navy-950/80 px-3 py-2.5 md:px-4">
          <!-- touch movement pad -->
          <div id="g-touch" class="flex flex-1 flex-wrap items-center gap-1.5 md:gap-2">
            <button data-hold="turnL" class="g-pad rounded-xl bg-white/10 px-3.5 py-2 font-heading text-lg font-bold text-white ring-1 ring-white/15 transition active:scale-95 active:bg-white/25" aria-label="Turn left">↺</button>
            <button data-hold="fwd" class="g-pad rounded-xl bg-white/10 px-3.5 py-2 font-heading text-lg font-bold text-white ring-1 ring-white/15 transition active:scale-95 active:bg-white/25" aria-label="Move forward">▲</button>
            <button data-hold="back" class="g-pad rounded-xl bg-white/10 px-3.5 py-2 font-heading text-lg font-bold text-white ring-1 ring-white/15 transition active:scale-95 active:bg-white/25" aria-label="Move back">▼</button>
            <button data-hold="turnR" class="g-pad rounded-xl bg-white/10 px-3.5 py-2 font-heading text-lg font-bold text-white ring-1 ring-white/15 transition active:scale-95 active:bg-white/25" aria-label="Turn right">↻</button>
          </div>
          <button id="g-serve" class="rounded-full bg-brand-500 px-6 py-2.5 font-heading text-xs font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition hover:bg-brand-600 active:scale-95 md:px-8 md:text-sm" aria-label="Serve / fire">Serve</button>
          <button id="g-pause" class="rounded-full bg-white/10 px-3 py-2 text-sm font-bold text-white transition hover:bg-white/20" aria-label="Pause game">⏸</button>
          <button id="g-mute" class="rounded-full bg-white/10 px-3 py-2 text-sm font-bold text-white transition hover:bg-white/20" aria-label="Toggle sound">♪</button>
          <button id="g-quit" class="rounded-full bg-white/10 px-3 py-2 text-sm font-bold text-white transition hover:bg-white/20" aria-label="Quit to title">✕</button>
        </div>

        <!-- HOW TO PLAY -->
        <div data-screen="howto" class="relative px-6 py-12 md:px-12" hidden>
          <h2 class="text-center font-heading text-2xl font-extrabold text-white md:text-3xl">How to Play</h2>
          <div class="mx-auto mt-8 grid max-w-2xl gap-4">
            <div class="rounded-2xl bg-white/[0.07] p-5 ring-1 ring-white/10">
              <p class="font-heading text-sm font-bold uppercase tracking-wider text-gold">1 · Move through the concourse</p>
              <p class="mt-1.5 text-sm leading-relaxed text-navy-100">
                It's a first-person run. <strong class="text-white">Keyboard:</strong>
                <kbd class="rounded bg-white/15 px-1.5 font-bold">W</kbd><kbd class="rounded bg-white/15 px-1.5 font-bold">A</kbd><kbd class="rounded bg-white/15 px-1.5 font-bold">S</kbd><kbd class="rounded bg-white/15 px-1.5 font-bold">D</kbd> to move,
                <kbd class="rounded bg-white/15 px-1.5 font-bold">←</kbd>/<kbd class="rounded bg-white/15 px-1.5 font-bold">→</kbd> (or the mouse) to look.
                <strong class="text-white">Touch:</strong> use the on-screen pad to turn and step.</p>
            </div>
            <div class="rounded-2xl bg-white/[0.07] p-5 ring-1 ring-white/10">
              <p class="font-heading text-sm font-bold uppercase tracking-wider text-gold">2 · Serve the hangry crowd</p>
              <p class="mt-1.5 text-sm leading-relaxed text-navy-100">Fans swarm toward your counter. Aim and <kbd class="rounded bg-white/15 px-1.5 font-bold">Space</kbd> (or tap <strong class="text-white">Serve</strong>) to slide them a snack. A served fan cheers and drops a tip. Let them crowd you and your <strong class="text-white">patience</strong> drains — run out and you're sent home early.</p>
            </div>
            <div class="rounded-2xl bg-white/[0.07] p-5 ring-1 ring-white/10">
              <p class="font-heading text-sm font-bold uppercase tracking-wider text-gold">3 · Restock & clock out</p>
              <p class="mt-1.5 text-sm leading-relaxed text-navy-100">Grab <strong class="text-white">snack crates</strong> for more to serve and <strong class="text-white">energy drinks</strong> to recover patience. Serve enough fans to calm the crowd, then reach the glowing <strong class="text-gold">Clock-Out</strong> gate to end your shift. 20% of everything you earn goes to your college fund — just like Juma's real savings program.</p>
            </div>
            <div class="rounded-2xl bg-white/[0.07] p-5 ring-1 ring-white/10">
              <p class="font-heading text-sm font-bold uppercase tracking-wider text-gold">4 · Learn & climb</p>
              <p class="mt-1.5 text-sm leading-relaxed text-navy-100">After each shift, a Money Minute question raises Juma's match on your savings — up to 100%. Four shifts, four real venues, four promotions: Crew Member to Enterprise Manager.</p>
            </div>
          </div>
          <div class="mt-8 text-center">
            <button id="g-howto-back" class="rounded-full border-2 border-white/70 px-8 py-3 font-heading text-sm font-bold uppercase tracking-wider text-white transition hover:bg-white hover:text-navy-900">Back</button>
          </div>
        </div>

        <!-- SHIFT INTRO (Connect) -->
        <div data-screen="intro" class="relative px-6 py-14 text-center md:py-16" hidden>
          <p id="g-intro-kicker" class="eyebrow eyebrow-center justify-center text-gold"></p>
          <h2 id="g-intro-role" class="mt-5 font-heading text-3xl font-extrabold text-white md:text-4xl"></h2>
          <p id="g-intro-venue" class="mt-3 font-heading text-lg font-bold text-brand-300"></p>
          <p id="g-intro-blurb" class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-navy-100"></p>
          <p id="g-intro-menu" class="mx-auto mt-5 max-w-md font-heading text-xs font-bold uppercase tracking-widest text-navy-300"></p>
          <div class="mt-8">
            <button id="g-shift-go" class="rounded-full bg-brand-500 px-10 py-4 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-600 md:text-base">Clock In</button>
          </div>
        </div>

        <!-- SHIFT SUMMARY + MONEY MINUTE (Learn) -->
        <div data-screen="learn" class="relative px-5 py-10 md:px-10" hidden>
          <p class="eyebrow eyebrow-center justify-center text-gold">Shift complete</p>
          <h2 id="g-sum-title" class="mt-2 text-center font-heading text-2xl font-extrabold text-white md:text-3xl"></h2>
          <dl id="g-sum-stats" class="mx-auto mt-6 grid max-w-xl grid-cols-2 gap-3 sm:grid-cols-4"></dl>

          <div class="mx-auto mt-8 max-w-xl rounded-2xl bg-white/[0.07] p-6 ring-1 ring-white/10">
            <p class="font-heading text-xs font-bold uppercase tracking-[0.2em] text-sky">Money Minute</p>
            <p id="g-quiz-q" class="mt-3 font-heading text-lg font-bold leading-snug text-white"></p>
            <div id="g-quiz-opts" class="mt-4 grid gap-2"></div>
            <div id="g-quiz-result" class="mt-4 hidden rounded-xl p-4 text-sm leading-relaxed"></div>
          </div>

          <div class="mt-8 text-center">
            <button id="g-learn-next" class="hidden rounded-full bg-brand-500 px-10 py-4 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-600"></button>
          </div>
        </div>

        <!-- FINAL RESULTS -->
        <div data-screen="final" class="relative px-5 py-12 text-center md:px-10" hidden>
          <p class="eyebrow eyebrow-center justify-center text-gold">Season complete</p>
          <p id="g-final-stars" class="mt-4 text-4xl tracking-wide" aria-label="Star rating"></p>
          <h2 class="mt-3 font-heading text-3xl font-extrabold text-white md:text-4xl">What a season!</h2>
          <p id="g-final-newbest" class="mt-2 hidden font-heading text-sm font-bold uppercase tracking-widest text-gold">New personal best!</p>

          <div class="mx-auto mt-8 max-w-xl rounded-2xl bg-white/[0.07] p-6 text-left ring-1 ring-white/10">
            <dl class="space-y-2.5 text-sm">
              <div class="flex justify-between gap-4"><dt class="text-navy-200">Wages & tips earned</dt><dd id="g-final-earned" class="font-heading font-bold text-white"></dd></div>
              <div class="flex justify-between gap-4"><dt class="text-navy-200">Saved to your college fund (20%)</dt><dd id="g-final-saved" class="font-heading font-bold text-white"></dd></div>
              <div class="flex justify-between gap-4"><dt class="text-navy-200">Juma savings match</dt><dd id="g-final-match" class="font-heading font-bold text-sky"></dd></div>
              <div class="flex justify-between gap-4 border-t border-white/15 pt-2.5"><dt class="font-heading font-bold text-white">Total season score</dt><dd id="g-final-score" class="font-heading text-lg font-extrabold text-gold"></dd></div>
            </dl>
            <p id="g-final-line" class="mt-4 border-t border-white/15 pt-4 text-xs leading-relaxed text-navy-200"></p>
          </div>

          <p class="mt-8 font-heading text-xs font-bold uppercase tracking-[0.2em] text-navy-300">Badges</p>
          <div id="g-badges" class="mx-auto mt-3 flex max-w-xl flex-wrap justify-center gap-2"></div>

          <div class="mx-auto mt-9 max-w-lg rounded-2xl bg-gradient-to-r from-brand-600/40 to-brand-500/20 p-5 ring-1 ring-brand-400/30">
            <p class="text-sm leading-relaxed text-white">This is a game — but for <strong>462 young people last year</strong>, it was a real paycheck. Juma youth earned <strong>$1.3M in wages</strong> at venues just like these.</p>
          </div>

          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <button id="g-again" class="rounded-full bg-brand-500 px-8 py-3.5 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-600">Play Again</button>
            <a href="/donate/" class="rounded-full bg-white px-8 py-3.5 font-heading text-sm font-bold uppercase tracking-wider text-navy-900 transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold">Donate for Real</a>
            <a href="/apply/" class="rounded-full border-2 border-white/70 px-8 py-3.5 font-heading text-sm font-bold uppercase tracking-wider text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-white hover:text-navy-900">Youth: Apply</a>
          </div>
        </div>
      </div>

      <p class="mt-4 text-center text-xs text-warmgray">
        <span class="hidden md:inline">Keyboard: <kbd class="rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">W</kbd><kbd class="ml-1 rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">A</kbd><kbd class="ml-1 rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">S</kbd><kbd class="ml-1 rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">D</kbd> move · <kbd class="rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">←</kbd><kbd class="ml-1 rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">→</kbd> / mouse look · <kbd class="rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">Space</kbd> serve · <kbd class="rounded bg-white px-1.5 py-0.5 font-bold shadow-sm ring-1 ring-navy-200">P</kbd> pause</span>
        <span class="md:hidden">Use the on-screen pad to move and turn, then tap Serve. Best played in landscape.</span>
      </p>
    </Container>
  </section>

  <!-- The real model behind the game -->
  <section class="bg-white">
    <Container class="py-16 md:py-24">
      <div class="mx-auto mb-12 max-w-2xl text-center" data-reveal>
        <p class="eyebrow eyebrow-center justify-center text-brand-600">More than a game</p>
        <h2 class="mt-3 text-3xl md:text-4xl">Every mechanic is the real Juma model</h2>
        <p class="mt-4 text-lg text-ink-soft">Concourse Rush mirrors how Juma actually works with young people ages 16–24.</p>
      </div>
      <div class="grid gap-7 md:grid-cols-3">
        <div class="card-lift relative overflow-hidden rounded-[var(--radius-card)] border border-navy-100 bg-white p-7 shadow-[var(--shadow-card)]" data-reveal>
          <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-brand-500 to-brand-300" aria-hidden="true"></div>
          <h3 class="text-xl">Serving fans = Earn</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">Juma youth really do run concession stands at Oracle Park, Levi's Stadium, Golden 1 Center, and Lumen Field — earning a first paycheck in a supportive environment.</p>
        </div>
        <div class="card-lift relative overflow-hidden rounded-[var(--radius-card)] border border-navy-100 bg-white p-7 shadow-[var(--shadow-card)]" data-reveal style="--reveal-delay: 100ms">
          <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-accent to-gold" aria-hidden="true"></div>
          <h3 class="text-xl">Money Minutes = Learn</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">The quiz questions come from real financial-capability skills Juma teaches — budgeting, saving, credit, and reading your first paycheck. Matched savings is a real Juma practice.</p>
        </div>
        <div class="card-lift relative overflow-hidden rounded-[var(--radius-card)] border border-navy-100 bg-white p-7 shadow-[var(--shadow-card)]" data-reveal style="--reveal-delay: 200ms">
          <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-navy-600 to-sky" aria-hidden="true"></div>
          <h3 class="text-xl">Promotions = Connect</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">Climbing from Crew Member to Enterprise Manager mirrors how Juma connects youth to their next job or education step — a lasting path, not just a shift.</p>
        </div>
      </div>
      <div class="mt-12 text-center" data-reveal>
        <Button href="/programs/" variant="outline" size="lg" arrow>Explore the real programs</Button>
      </div>
    </Container>
  </section>
</BaseLayout>

<script>
  // ================================================================
  // Juma: Concourse Rush — a first-person, Doom-style raycaster,
  // reskinned to Juma's real youth-jobs model. You work the stadium
  // concourse: serve the hangry crowd, earn tips, restock, and reach
  // the Clock-Out gate. All art is drawn procedurally; sound is
  // synthesized with ZzFX (MIT, by Frank Force) — no binary assets.
  // Earn (serve fans) · Learn (Money Minute) · Connect (promotions).
  // ================================================================
  import { zzfx, ZZFX } from "zzfx";
  const W = 960;
  const H = 620;
  const HUD_H = 108;
  const VIEW_W = W;
  const VIEW_H = H - HUD_H;
  const TEX = 64;
  const SAVE_RATE = 0.2;
  const BEST_KEY = "jumaConcourseBest";

  // ---------- snack catalog (what you serve) ----------
  const FOODS = {
    hotdog: { name: "Hot Dog", price: 6 },
    soda: { name: "Soda", price: 4 },
    popcorn: { name: "Popcorn", price: 5 },
    pretzel: { name: "Pretzel", price: 5 },
    nachos: { name: "Nachos", price: 7 },
    coffee: { name: "Coffee", price: 3 },
  };

  // Each level is a real Juma venue. Maps are built procedurally from
  // a size + interior pillar list so they're always enclosed & solvable.
  const LEVELS = [
    {
      city: "San Francisco", venue: "Oracle Park", sport: "baseball", role: "Crew Member",
      menu: ["hotdog", "soda"], w: 14, h: 12, enemies: 9, quota: 6, spawnEvery: 2.6, speed: 1.0,
      pillars: [[4,3],[5,3],[9,4],[9,5],[3,7],[8,8],[8,9],[10,2]], start: [2, 2, 0],
      blurb: "Your first shift — a sunny day game by the bay. A small, friendly concourse. Learn the ropes: serve the crowd, grab tips, find the Clock-Out gate.",
    },
    {
      city: "San Jose", venue: "Levi's Stadium", sport: "football", role: "Team Lead",
      menu: ["hotdog", "soda", "popcorn"], w: 18, h: 14, enemies: 14, quota: 9, spawnEvery: 2.2, speed: 1.12,
      pillars: [[4,3],[5,3],[12,3],[13,3],[8,6],[9,6],[4,9],[5,9],[12,10],[13,10],[8,11]], start: [2, 2, 0],
      blurb: "Football crowds are bigger and hungrier. More aisles, more fans, faster rush. Lead the line and keep your patience up.",
    },
    {
      city: "Sacramento", venue: "Golden 1 Center", sport: "basketball", role: "Shift Supervisor",
      menu: ["hotdog", "soda", "popcorn", "pretzel"], w: 20, h: 16, enemies: 18, quota: 12, spawnEvery: 1.9, speed: 1.22,
      pillars: [[4,3],[5,3],[15,3],[16,3],[9,5],[10,5],[4,8],[5,8],[14,9],[15,9],[9,11],[10,11],[6,13],[13,13]], start: [2, 2, 0],
      blurb: "Halftime rush at the arena. The maze gets tighter and the fans move quick. Keep your serve streak alive for bigger tips.",
    },
    {
      city: "Seattle", venue: "Lumen Field", sport: "soccer", role: "Enterprise Manager",
      menu: ["hotdog", "soda", "popcorn", "pretzel", "nachos", "coffee"], w: 22, h: 16, enemies: 24, quota: 16, spawnEvery: 1.7, speed: 1.32,
      pillars: [[4,3],[5,3],[17,3],[18,3],[10,4],[11,4],[4,7],[5,7],[16,8],[17,8],[9,10],[10,10],[4,12],[18,12],[13,12],[7,13]], start: [2, 2, 0],
      blurb: "The loudest stadium in the league — the biggest concourse and the wildest rush. Finish the season strong, hero.",
    },
  ];

  const QUIZ = [
    { q: "“Pay yourself first” means…", opts: ["Spend on fun stuff before bills", "Move money to savings as soon as you're paid", "Pay your rent before anything else", "Ask for your wages in cash"], a: 1, why: "Saving a slice of every paycheck before you spend makes saving automatic — exactly how your 20% college fund works in this game." },
    { q: "Your paycheck's “net pay” is…", opts: ["Your hourly rate × hours", "Your pay before taxes", "Your take-home pay after taxes and deductions", "Your tips only"], a: 2, why: "Gross pay is what you earn; net pay is what actually lands in your account after taxes and deductions." },
    { q: "Compound interest is when you earn interest on…", opts: ["Only the money you deposited", "Your deposits AND the interest they've already earned", "Your paycheck", "Money you borrowed"], a: 1, why: "Interest earning interest is how small savings grow big over time — the earlier you start, the more it compounds." },
    { q: "In the 50/30/20 budget, the 20 stands for…", opts: ["Fun money", "Rent and bills", "Savings and paying down debt", "Groceries"], a: 2, why: "50% needs, 30% wants, 20% savings & debt — a simple starting framework for any paycheck." },
    { q: "The biggest factor in your credit score is…", opts: ["Paying your bills on time", "How many credit cards you own", "Your salary", "Your age"], a: 0, why: "Payment history matters most. One simple habit — paying on time, every time — builds strong credit." },
    { q: "A W-2 is…", opts: ["A job application", "A form showing your year's wages and taxes withheld", "A type of savings account", "A work permit"], a: 1, why: "Your employer sends a W-2 every January — you use it to file your taxes." },
    { q: "Money in an FDIC-insured savings account is…", opts: ["At risk if the bank fails", "Protected up to $250,000", "Locked for 5 years", "Only safe over $1,000"], a: 1, why: "FDIC insurance protects your deposits up to $250,000 — safer than cash under a mattress, and it earns interest." },
    { q: "An emergency fund is best used for…", opts: ["Concert tickets", "A surprise car repair or lost shifts", "A new phone upgrade", "Holiday gifts"], a: 1, why: "An emergency fund — even a small starter one — keeps a surprise expense from becoming a crisis or a debt." },
  ];

  const BADGES = [
    { id: "first", name: "First Serve", desc: "Serve your first fan" },
    { id: "fire", name: "On Fire", desc: "Reach an 8-serve streak" },
    { id: "tip", name: "Big Tipper", desc: "Earn a $6+ tip on one serve" },
    { id: "perfect", name: "Untouchable", desc: "Finish a shift without losing patience" },
    { id: "crowd", name: "Crowd Favorite", desc: "Clock out with 90%+ patience" },
    { id: "smart", name: "Money Smart", desc: "Answer every Money Minute right" },
    { id: "season", name: "Full Season", desc: "Complete all four shifts" },
  ];

  // ---------- DOM ----------
  const $ = (s) => document.querySelector(s);
  const root = $("#gameday");
  if (root) init();

  function init() {
    const canvas = $("#g-canvas");
    const ctx = canvas.getContext("2d");
    const dpr = Math.min(2, window.devicePixelRatio || 1);
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    ctx.scale(dpr, dpr);
    ctx.imageSmoothingEnabled = false;

    // ---------- audio (ZzFX synth + tiny sequenced music loop) ----------
    let muted = localStorage.getItem("jumaConcourseMuted") === "1";
    let musicTimer = 0;
    const audio = () => ZZFX.audioContext;
    function unlockAudio() {
      try { if (ZZFX.audioContext.state === "suspended") ZZFX.audioContext.resume(); } catch {}
    }
    document.addEventListener("pointerdown", unlockAudio, { once: true });
    document.addEventListener("keydown", unlockAudio, { once: true });

    const play = (params) => { if (!muted) try { zzfx(...params); } catch {} };
    const sfx = {
      step: () => play([0.08, , 90, , , 0.03, 1, 0.5, , , , , , 5]),
      serve: () => play([0.4, , 360, 0.01, 0.05, 0.18, 4, 1.6, -2, , , , , 0.6, , 0.1]),
      empty: () => play([0.2, , 220, , 0.02, 0.03, 4, 0.4, , , , , , 2]),
      coin: () => play([0.3, , 1875, , 0.05, 0.2, 1, 1.9, , , 950, 0.05]),
      hurt: () => play([0.4, , 154, 0.02, 0.06, 0.2, 4, 1.4, -4, , , , , 0.4, , 0.2]),
      pickup: () => play([0.3, , 539, 0, 0.04, 0.2, 1, 1.9, , , 700, 0.04, 0.02, , , , 0.03]),
      right: () => play([0.4, , 539, 0, 0.04, 0.29, 1, 1.92, , , 567, 0.02, 0.02, , , , 0.04]),
      wrong: () => play([0.4, , 154, 0.05, , 0.18, 4, 1.9, , , , , , , 1.2, , 0.1]),
      clockout: () => {
        play([0.4, , 539, 0, 0.04, 0.29, 1, 1.92, , , 567, 0.02, 0.02, , , , 0.04]);
        setTimeout(() => play([0.35, , 1675, , 0.06, 0.24, 1, 1.82, , , 837, 0.06]), 160);
        setTimeout(() => play([0.3, , 1875, , 0.06, 0.3, 1, 1.8, , , 999, 0.06]), 320);
      },
      promo: () => {
        play([0.4, , 539, 0, 0.04, 0.29, 1, 1.92, , , 567, 0.02, 0.02, , , , 0.04]);
        setTimeout(() => play([0.35, , 1675, , 0.06, 0.24, 1, 1.82, , , 837, 0.06]), 180);
        setTimeout(() => play([0.3, , 1875, , 0.06, 0.3, 1, 1.8, , , 999, 0.06]), 360);
      },
      whistle: () => { play([0.3, , 880, 0.01, 0.18, 0.1, 2, 1]); setTimeout(() => play([0.3, , 880, 0.01, 0.22, 0.12, 2, 1]), 300); },
    };

    function blipAt(a, freq, t, dur, type, gain) {
      try {
        const o = a.createOscillator();
        const g = a.createGain();
        o.type = type;
        o.frequency.value = freq;
        g.gain.setValueAtTime(gain, t);
        g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
        o.connect(g).connect(a.destination);
        o.start(t);
        o.stop(t + dur + 0.02);
      } catch {}
    }

    // Tiny driving chiptune: walking bass + pentatonic lead, scheduled per bar.
    const BASS = [98, 98, 131, 98, 110, 110, 147, 110];
    const LEAD = [392, 0, 440, 523, 0, 587, 523, 440, 392, 0, 330, 392, 440, 0, 330, 294];
    function scheduleMusic() {
      if (muted || G.mode !== "play" || G.paused) return;
      const a = audio();
      const beat = 60 / 124 / 2; // 8th notes at 124bpm
      const start = Math.max(a.currentTime + 0.05, musicTimer);
      for (let i = 0; i < 16; i++) {
        const t = start + i * beat;
        const b = BASS[i % 8];
        blipAt(a, b, t, beat * 0.9, "triangle", 0.03);
        const l = LEAD[i];
        if (l) blipAt(a, l, t, beat * 0.7, "square", 0.014);
      }
      musicTimer = start + 16 * beat;
    }

    // ---------- helpers ----------
    const money = (n) => "$" + Math.round(n).toLocaleString("en-US");
    const rand = (a, b) => a + Math.random() * (b - a);
    const randInt = (a, b) => Math.floor(rand(a, b + 1));
    const pick = (arr) => arr[randInt(0, arr.length - 1)];
    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const lerp = (a, b, t) => a + (b - a) * t;
    const norm = (a) => { while (a > Math.PI) a -= Math.PI * 2; while (a < -Math.PI) a += Math.PI * 2; return a; };

    // ---------- palettes per venue ----------
    const SPORTS = {
      baseball: { wall: [62, 70, 110], wall2: [48, 54, 92], ceil: "#161a2e", floor: "#262b40", accent: "#3e7d4f" },
      football: { wall: [58, 64, 96], wall2: [44, 49, 78], ceil: "#13182a", floor: "#222740", accent: "#2f6e44" },
      basketball: { wall: [78, 66, 60], wall2: [60, 50, 46], ceil: "#1a1410", floor: "#2c2520", accent: "#b97a3c" },
      soccer: { wall: [56, 70, 92], wall2: [42, 54, 74], ceil: "#10182a", floor: "#1f2a3c", accent: "#35784a" },
    };

    // ================================================================
    // Procedural texture & sprite generation (offscreen canvases)
    // ================================================================
    const mkCanvas = (w, h) => { const c = document.createElement("canvas"); c.width = w; c.height = h; return c; };

    function rgb(a, m = 1) { return `rgb(${a[0] * m | 0},${a[1] * m | 0},${a[2] * m | 0})`; }

    // Concrete-block concourse wall, tinted to the venue.
    function makeWallTex(base) {
      const c = mkCanvas(TEX, TEX), x = c.getContext("2d");
      x.fillStyle = rgb(base);
      x.fillRect(0, 0, TEX, TEX);
      // subtle noise
      for (let i = 0; i < 240; i++) {
        const m = rand(0.82, 1.12);
        x.fillStyle = `rgba(${base[0] * m | 0},${base[1] * m | 0},${base[2] * m | 0},0.5)`;
        x.fillRect(rand(0, TEX) | 0, rand(0, TEX) | 0, 2, 2);
      }
      // mortar block lines
      x.strokeStyle = "rgba(0,0,0,0.4)";
      x.lineWidth = 1;
      for (let y = 0; y <= TEX; y += 16) {
        x.beginPath(); x.moveTo(0, y + 0.5); x.lineTo(TEX, y + 0.5); x.stroke();
      }
      for (let row = 0; row < 4; row++) {
        const off = row % 2 ? 0 : 16;
        for (let bx = off; bx <= TEX; bx += 32) {
          x.beginPath(); x.moveTo(bx + 0.5, row * 16); x.lineTo(bx + 0.5, row * 16 + 16); x.stroke();
        }
      }
      // top highlight
      x.fillStyle = "rgba(255,255,255,0.06)";
      x.fillRect(0, 0, TEX, 2);
      return c;
    }

    // Branded ad-board wall ("JUMA" / EARN·LEARN·CONNECT).
    function makeAdTex(variant) {
      const c = mkCanvas(TEX, TEX), x = c.getContext("2d");
      const bg = variant ? "#e33a5e" : "#fdbf51";
      const fg = variant ? "#ffffff" : "#2b2e49";
      x.fillStyle = "#2b2e49"; x.fillRect(0, 0, TEX, TEX);
      x.fillStyle = bg;
      x.fillRect(4, 10, TEX - 8, TEX - 20);
      x.fillStyle = fg;
      x.textAlign = "center";
      x.font = "800 17px sans-serif";
      x.fillText("JUMA", TEX / 2, 32);
      x.font = "700 6px sans-serif";
      x.fillText("EARN·LEARN·CONNECT", TEX / 2, 44);
      // frame studs
      x.fillStyle = "rgba(0,0,0,0.35)";
      for (let i = 6; i < TEX; i += 12) { x.fillRect(i, 5, 2, 2); x.fillRect(i, TEX - 7, 2, 2); }
      return c;
    }

    // Glowing Clock-Out (exit) gate.
    function makeExitTex() {
      const c = mkCanvas(TEX, TEX), x = c.getContext("2d");
      const g = x.createLinearGradient(0, 0, 0, TEX);
      g.addColorStop(0, "#1f7d52"); g.addColorStop(1, "#0f5236");
      x.fillStyle = g; x.fillRect(0, 0, TEX, TEX);
      x.strokeStyle = "#9bdbf3"; x.lineWidth = 3; x.strokeRect(5, 5, TEX - 10, TEX - 10);
      x.fillStyle = "#eafff4";
      x.textAlign = "center";
      x.font = "800 13px sans-serif";
      x.fillText("CLOCK", TEX / 2, 28);
      x.fillText("OUT", TEX / 2, 44);
      x.fillStyle = "#fdbf51";
      x.font = "800 16px sans-serif";
      x.fillText("▼", TEX / 2, 60);
      return c;
    }

    let TEXES = {};
    function buildTextures(sport) {
      const p = SPORTS[sport];
      TEXES = {
        1: makeWallTex(p.wall),
        4: makeWallTex(p.wall2),
        5: makeAdTex(0),
        6: makeAdTex(1),
        9: makeExitTex(),
      };
    }

    // ---- sprite: a front-facing fan (hangry or cheering) ----
    const SKINS = ["#f2c89b", "#e0a370", "#b97a4e", "#8d5a36", "#6e4226", "#f7d7b6"];
    const SHIRTS = ["#4d588f", "#2f9e6e", "#d97f2e", "#7a4dab", "#3a8fb5", "#c2483e", "#5d6b25", "#9b3d6e"];
    const HAIRC = ["#241c14", "#4a3320", "#9c5b2a", "#b8b8b8", "#1f2c4d", "#7a2c1d"];
    const SPR_W = 72, SPR_H = 108;

    function drawFanSprite(o, mood) {
      const c = mkCanvas(SPR_W, SPR_H), x = c.getContext("2d");
      const cx = SPR_W / 2;
      const footY = SPR_H - 4;
      x.lineCap = "round";
      // shadow
      x.fillStyle = "rgba(0,0,0,0.28)";
      x.beginPath(); x.ellipse(cx, footY + 1, 20, 5, 0, 0, 7); x.fill();
      // legs
      x.strokeStyle = o.pants; x.lineWidth = 8;
      x.beginPath(); x.moveTo(cx - 7, footY - 30); x.lineTo(cx - 8, footY); x.stroke();
      x.beginPath(); x.moveTo(cx + 7, footY - 30); x.lineTo(cx + 8, footY); x.stroke();
      x.fillStyle = "#22253a";
      x.beginPath(); x.ellipse(cx - 8, footY, 6, 3.5, 0, 0, 7); x.fill();
      x.beginPath(); x.ellipse(cx + 8, footY, 6, 3.5, 0, 0, 7); x.fill();
      // torso
      const ty = footY - 64;
      x.fillStyle = o.shirt;
      x.beginPath(); x.roundRect(cx - 16, ty, 32, 38, 9); x.fill();
      // arms
      x.strokeStyle = o.shirt; x.lineWidth = 8;
      if (mood === "happy") {
        // arms up cheering
        x.beginPath(); x.moveTo(cx - 13, ty + 6); x.lineTo(cx - 24, ty - 12); x.stroke();
        x.beginPath(); x.moveTo(cx + 13, ty + 6); x.lineTo(cx + 24, ty - 12); x.stroke();
        x.fillStyle = o.skin;
        x.beginPath(); x.arc(cx - 24, ty - 14, 4.5, 0, 7); x.fill();
        x.beginPath(); x.arc(cx + 24, ty - 14, 4.5, 0, 7); x.fill();
      } else {
        x.beginPath(); x.moveTo(cx - 13, ty + 6); x.lineTo(cx - 22, ty + 30); x.stroke();
        x.beginPath(); x.moveTo(cx + 13, ty + 6); x.lineTo(cx + 22, ty + 30); x.stroke();
      }
      // head
      const hy = ty - 12;
      x.fillStyle = o.skin;
      x.beginPath(); x.arc(cx, hy, 15, 0, 7); x.fill();
      // hair
      x.fillStyle = o.hairC;
      if (o.hair === "afro") { x.beginPath(); x.arc(cx, hy - 6, 18, 0, 7); x.fill(); x.fillStyle = o.skin; x.beginPath(); x.arc(cx, hy + 2, 13, 0, 7); x.fill(); }
      else if (o.hair === "long") { x.beginPath(); x.arc(cx, hy - 2, 16, Math.PI, 0); x.fill(); x.fillRect(cx - 16, hy - 2, 5, 22); x.fillRect(cx + 11, hy - 2, 5, 22); }
      else if (o.hair === "bun") { x.beginPath(); x.arc(cx, hy - 2, 15, Math.PI, 0); x.fill(); x.beginPath(); x.arc(cx, hy - 18, 6, 0, 7); x.fill(); }
      else if (o.hair !== "none") { x.beginPath(); x.arc(cx, hy - 3, 15, Math.PI, 0); x.fill(); }
      // hat (team cap)
      if (o.hat) {
        x.fillStyle = o.hat;
        x.beginPath(); x.arc(cx, hy - 4, 15, Math.PI, 0); x.fill();
        x.beginPath(); x.roundRect(cx, hy - 7, 19, 5, 2); x.fill();
      }
      // eyes
      x.fillStyle = "#1d1d24";
      x.beginPath(); x.arc(cx - 5, hy - 1, 2.1, 0, 7); x.fill();
      x.beginPath(); x.arc(cx + 5, hy - 1, 2.1, 0, 7); x.fill();
      x.strokeStyle = "#1d1d24"; x.lineWidth = 2;
      if (mood === "happy") {
        x.beginPath(); x.arc(cx, hy + 4, 5, 0.15, Math.PI - 0.15); x.stroke();
      } else {
        // hangry: frown + angry brows
        x.beginPath(); x.moveTo(cx - 5, hy + 7); x.quadraticCurveTo(cx, hy + 3, cx + 5, hy + 7); x.stroke();
        x.beginPath(); x.moveTo(cx - 8, hy - 6); x.lineTo(cx - 2, hy - 3); x.stroke();
        x.beginPath(); x.moveTo(cx + 8, hy - 6); x.lineTo(cx + 2, hy - 3); x.stroke();
        // anger mark
        x.strokeStyle = "#ff5a7a"; x.lineWidth = 2;
        x.beginPath(); x.moveTo(cx + 12, hy - 12); x.lineTo(cx + 17, hy - 9); x.moveTo(cx + 17, hy - 13); x.lineTo(cx + 12, hy - 8); x.stroke();
      }
      return c;
    }

    // pre-render a pool of fan looks (hangry + happy variants)
    const FAN_SPRITES = [];
    function buildFanSprites() {
      FAN_SPRITES.length = 0;
      for (let i = 0; i < 6; i++) {
        const o = {
          skin: pick(SKINS), shirt: pick(SHIRTS),
          pants: pick(["#2b3148", "#3d3d3d", "#5a4632", "#34495e"]),
          hair: pick(["short", "afro", "long", "bun", "none"]),
          hairC: pick(HAIRC),
          hat: Math.random() < 0.4 ? pick(["#e33a5e", "#1f6f50", "#2c5d8f", "#caa53d"]) : null,
        };
        FAN_SPRITES.push({ hangry: drawFanSprite(o, "hangry"), happy: drawFanSprite(o, "happy") });
      }
    }

    // ---- pickup sprites ----
    function makePickupSprite(kind) {
      const c = mkCanvas(48, 48), x = c.getContext("2d");
      x.lineCap = "round";
      x.fillStyle = "rgba(0,0,0,0.25)";
      x.beginPath(); x.ellipse(24, 44, 13, 4, 0, 0, 7); x.fill();
      if (kind === "tip") {
        x.fillStyle = "#fdbf51"; x.beginPath(); x.arc(24, 24, 14, 0, 7); x.fill();
        x.fillStyle = "#e8a93a"; x.beginPath(); x.arc(24, 24, 14, 0, 7); x.lineTo(24, 24); x.fill();
        x.fillStyle = "#fff3cf"; x.beginPath(); x.arc(24, 24, 9, 0, 7); x.fill();
        x.fillStyle = "#b07c1e"; x.font = "800 14px sans-serif"; x.textAlign = "center"; x.fillText("$", 24, 29);
      } else if (kind === "ammo") {
        // snack crate
        x.fillStyle = "#a96f3c"; x.beginPath(); x.roundRect(8, 14, 32, 26, 4); x.fill();
        x.fillStyle = "#7c4f28"; x.fillRect(8, 22, 32, 4);
        x.strokeStyle = "#d9a066"; x.lineWidth = 2; x.strokeRect(9, 15, 30, 24);
        x.fillStyle = "#fdbf51"; x.font = "800 9px sans-serif"; x.textAlign = "center"; x.fillText("SNACKS", 24, 35);
        // a hotdog poking out
        x.fillStyle = "#e8b06b"; x.beginPath(); x.ellipse(24, 13, 11, 4, 0, 0, 7); x.fill();
        x.fillStyle = "#c4502e"; x.beginPath(); x.roundRect(15, 8, 18, 5, 3); x.fill();
      } else {
        // energy drink (health)
        x.fillStyle = "#9bdbf3"; x.beginPath(); x.roundRect(15, 12, 18, 28, 4); x.fill();
        x.fillStyle = "#2f9e6e"; x.fillRect(15, 22, 18, 9);
        x.fillStyle = "#c9cdd6"; x.beginPath(); x.roundRect(14, 9, 20, 5, 2); x.fill();
        x.fillStyle = "#fff"; x.font = "800 9px sans-serif"; x.textAlign = "center"; x.fillText("+", 24, 30);
      }
      return c;
    }
    const PICKUP_SPRITES = {};
    function buildPickupSprites() {
      PICKUP_SPRITES.tip = makePickupSprite("tip");
      PICKUP_SPRITES.ammo = makePickupSprite("ammo");
      PICKUP_SPRITES.health = makePickupSprite("health");
    }

    // ================================================================
    // Game state
    // ================================================================
    const G = {
      mode: "attract", // attract | play | off
      time: 0,
      paused: false,
      level: 0,
      // run totals
      earned: 0, fund: 0, match: 0, matchRate: 0.25,
      served: 0, missed: 0, streak: 0, bestStreak: 0,
      quizAsked: [], quizRight: 0, badges: new Set(),
      // shift
      sServed: 0, sEarned: 0, shiftDmg: 0, exitOpen: false, spawnIn: 1, spawnedTotal: 0,
      health: 100, ammo: 20,
      map: null, mapW: 0, mapH: 0,
      player: { x: 2.5, y: 2.5, ang: 0, bob: 0, cooldown: 0, recoil: 0, muzzle: 0, hurt: 0 },
      fans: [], pickups: [], floats: [],
      shake: 0,
    };
    window.__GD = G;

    const lvl = () => LEVELS[G.level];
    const keys = {};

    // ---------- map building ----------
    function buildMap(L) {
      const w = L.w, h = L.h;
      const grid = [];
      for (let y = 0; y < h; y++) {
        const row = [];
        for (let x = 0; x < w; x++) {
          row.push(x === 0 || y === 0 || x === w - 1 || y === h - 1 ? 1 : 0);
        }
        grid.push(row);
      }
      // interior pillars (alternate plain/ad walls for variety)
      L.pillars.forEach(([px, py], i) => {
        if (py > 0 && py < h - 1 && px > 0 && px < w - 1) grid[py][px] = i % 3 === 0 ? (i % 2 ? 6 : 5) : (i % 2 ? 4 : 1);
      });
      // exit gate on the far corner border, with floor in front of it
      const ex = w - 1, ey = h - 2;
      grid[ey][ex] = 9;
      grid[ey][ex - 1] = 0;
      G.map = grid; G.mapW = w; G.mapH = h;
      G.exit = { x: ex - 0.5, y: ey + 0.5, cx: ex, cy: ey };
    }

    const cellAt = (x, y) => {
      const ix = x | 0, iy = y | 0;
      if (ix < 0 || iy < 0 || iy >= G.mapH || ix >= G.mapW) return 1;
      return G.map[iy][ix];
    };
    const blocked = (x, y) => {
      const c = cellAt(x, y);
      return c !== 0 && c !== 9; // exit (9) is passable-ish; handled separately
    };

    function freeFloorCell(minDistFromPlayer) {
      const p = G.player;
      for (let tries = 0; tries < 120; tries++) {
        const x = randInt(1, G.mapW - 2) + 0.5;
        const y = randInt(1, G.mapH - 2) + 0.5;
        if (G.map[y | 0][x | 0] !== 0) continue;
        if (Math.hypot(x - p.x, y - p.y) < minDistFromPlayer) continue;
        return { x, y };
      }
      return { x: G.mapW / 2, y: G.mapH / 2 };
    }

    // ---------- entities ----------
    function spawnFan() {
      const L = lvl();
      const c = freeFloorCell(4.5);
      const look = randInt(0, FAN_SPRITES.length - 1);
      G.fans.push({
        x: c.x, y: c.y, look,
        want: pick(L.menu),
        hp: 1 + (G.level >= 2 ? (Math.random() < 0.25 ? 1 : 0) : 0),
        speed: rand(0.85, 1.15) * L.speed,
        state: "hangry", t: 0, attackCd: rand(0.2, 0.8), bob: rand(0, 6),
        scale: 1,
      });
      G.spawnedTotal++;
    }

    function spawnPickup(kind, near) {
      const c = near || freeFloorCell(2.5);
      G.pickups.push({ x: c.x, y: c.y, kind, t: rand(0, 6) });
    }

    function addFloat(text, color = "#fdbf51") {
      // floating HUD text near screen center
      G.floats.push({ text, color, t: 0 });
    }

    // line-of-sight: is the straight path from player to (tx,ty) wall-free?
    function losClear(tx, ty) {
      const p = G.player;
      const dx = tx - p.x, dy = ty - p.y;
      const dist = Math.hypot(dx, dy);
      const steps = Math.ceil(dist * 4);
      for (let i = 1; i < steps; i++) {
        const t = i / steps;
        if (blocked(p.x + dx * t, p.y + dy * t)) return false;
      }
      return true;
    }

    // ---------- firing (hitscan "serve") ----------
    function serve() {
      const p = G.player;
      if (G.mode !== "play" || G.paused || p.cooldown > 0) return;
      if (G.ammo <= 0) { sfx.empty(); addFloat("Out of snacks! Grab a crate", "#ff7b9a"); return; }
      G.ammo--;
      p.cooldown = 0.34;
      p.recoil = 1;
      p.muzzle = 1;
      sfx.serve();
      // find best target within an aim cone + line of sight, nearest first
      let best = null, bestDist = 1e9;
      for (const f of G.fans) {
        if (f.state !== "hangry") continue;
        const dx = f.x - p.x, dy = f.y - p.y;
        const dist = Math.hypot(dx, dy);
        if (dist > 11) continue;
        const diff = Math.abs(norm(Math.atan2(dy, dx) - p.ang));
        // generous cone that tightens slightly with distance
        if (diff > 0.16 + 0.5 / Math.max(1, dist)) continue;
        if (!losClear(f.x, f.y)) continue;
        if (dist < bestDist) { bestDist = dist; best = f; }
      }
      if (best) hitFan(best, bestDist);
    }

    function hitFan(f, dist) {
      f.hp--;
      if (f.hp > 0) { f.flash = 0.15; return; }
      // served!
      f.state = "happy"; f.t = 0;
      const tip = Math.round(1 + clamp((12 - dist) / 12, 0, 1) * 5 + Math.min(G.streak, 10) * 0.3);
      const total = FOODS[f.want].price + tip;
      G.earned += total; G.fund += total * SAVE_RATE;
      G.sEarned += total;
      G.served++; G.sServed++;
      G.streak++; G.bestStreak = Math.max(G.bestStreak, G.streak);
      G.badges.add("first");
      if (G.streak >= 8) G.badges.add("fire");
      if (tip >= 6) G.badges.add("tip");
      addFloat(`Served! +${money(total)}`, "#fdbf51");
      if (tip >= 5) addFloat("BIG TIP!", "#9bdbf3");
      sfx.coin();
      // a served fan sometimes leaves a tip you can grab
      if (Math.random() < 0.5) spawnPickup("tip", { x: f.x, y: f.y });
      // progress toward opening the gate
      if (!G.exitOpen && G.sServed >= lvl().quota) openExit();
    }

    function openExit() {
      G.exitOpen = true;
      addFloat("Crowd's happy — Clock-Out gate is open!", "#9bdbf3");
      sfx.clockout();
    }

    // ---------- update ----------
    function update(dt) {
      G.time += dt;
      const p = G.player;

      if (G.mode === "attract") {
        // slow auto-rotating fly-through of level 1 with wandering fans
        p.ang += dt * 0.32;
        for (const f of G.fans) {
          f.bob += dt;
          const tx = G.mapW / 2, ty = G.mapH / 2;
          const a = Math.atan2(ty - f.y, tx - f.x) + Math.sin(G.time + f.x) * 0.6;
          const nx = f.x + Math.cos(a) * 0.4 * dt, ny = f.y + Math.sin(a) * 0.4 * dt;
          if (!blocked(nx, f.y)) f.x = nx;
          if (!blocked(f.x, ny)) f.y = ny;
        }
        return;
      }
      if (G.mode !== "play" || G.paused) return;

      G.shake = Math.max(0, G.shake - dt * 2);
      p.cooldown = Math.max(0, p.cooldown - dt);
      p.recoil = Math.max(0, p.recoil - dt * 4);
      p.muzzle = Math.max(0, p.muzzle - dt * 6);
      p.hurt = Math.max(0, p.hurt - dt * 1.6);

      // ----- player movement -----
      const turn = 2.6, moveSpd = 2.7;
      if (keys.turnL) p.ang -= turn * dt;
      if (keys.turnR) p.ang += turn * dt;
      let mf = 0, ms = 0;
      if (keys.fwd) mf += 1;
      if (keys.back) mf -= 1;
      if (keys.left) ms -= 1;
      if (keys.right) ms += 1;
      if (mf || ms) {
        const len = Math.hypot(mf, ms) || 1;
        const vx = (Math.cos(p.ang) * mf - Math.sin(p.ang) * ms) / len * moveSpd * dt;
        const vy = (Math.sin(p.ang) * mf + Math.cos(p.ang) * ms) / len * moveSpd * dt;
        const r = 0.22;
        if (!blocked(p.x + vx + Math.sign(vx) * r, p.y)) p.x += vx;
        if (!blocked(p.x, p.y + vy + Math.sign(vy) * r)) p.y += vy;
        p.bob += dt * 9;
        if (Math.sin(p.bob) > 0.96) sfx.step();
      } else {
        p.bob = lerp(p.bob, 0, 1 - Math.exp(-dt * 8));
      }

      // ----- reached the open exit? -----
      if (G.exitOpen && Math.hypot(p.x - G.exit.x, p.y - G.exit.y) < 1.1) return endShift(true);

      // ----- spawn fans up to the level total -----
      G.spawnIn -= dt;
      const liveHangry = G.fans.filter((f) => f.state === "hangry").length;
      if (G.spawnIn <= 0 && G.spawnedTotal < lvl().enemies && liveHangry < 7) {
        spawnFan();
        G.spawnIn = lvl().spawnEvery * rand(0.75, 1.3);
      }

      // ----- fans -----
      for (const f of G.fans) {
        f.bob += dt;
        if (f.flash) f.flash = Math.max(0, f.flash - dt);
        if (f.state === "happy") { f.t += dt; continue; }
        f.attackCd -= dt;
        const dx = p.x - f.x, dy = p.y - f.y;
        const dist = Math.hypot(dx, dy);
        if (dist > 0.85) {
          // walk toward player (axis-separated so they slide along walls)
          const ux = dx / dist, uy = dy / dist;
          const step = f.speed * dt;
          if (!blocked(f.x + ux * step + Math.sign(ux) * 0.2, f.y)) f.x += ux * step;
          if (!blocked(f.x, f.y + uy * step + Math.sign(uy) * 0.2)) f.y += uy * step;
        } else if (f.attackCd <= 0) {
          // crowding you drains patience
          f.attackCd = 1.0;
          const dmg = 7 + G.level * 1.5;
          G.health = clamp(G.health - dmg, 0, 100);
          G.shiftDmg += dmg;
          G.streak = 0;
          p.hurt = 1;
          G.shake = 0.4;
          sfx.hurt();
          if (G.health <= 0) return endShift(false);
        }
      }
      // retire long-cheering fans
      G.fans = G.fans.filter((f) => !(f.state === "happy" && f.t > 0.9));

      // ----- pickups -----
      for (const it of G.pickups) {
        it.t += dt;
        if (Math.hypot(p.x - it.x, p.y - it.y) < 0.55) {
          it.dead = true;
          if (it.kind === "tip") { G.earned += 3; G.fund += 3 * SAVE_RATE; G.sEarned += 3; addFloat("+$3 tip", "#fdbf51"); sfx.coin(); }
          else if (it.kind === "ammo") { G.ammo += 8; addFloat("+8 snacks", "#9bdbf3"); sfx.pickup(); }
          else { G.health = clamp(G.health + 25, 0, 100); addFloat("+25 patience", "#7ee0a8"); sfx.pickup(); }
        }
      }
      G.pickups = G.pickups.filter((it) => !it.dead);

      // occasionally drop restock crates around the map
      if (Math.random() < dt * 0.16 && G.pickups.filter((x) => x.kind === "ammo").length < 2) spawnPickup("ammo");
      if (G.health < 55 && Math.random() < dt * 0.1 && G.pickups.filter((x) => x.kind === "health").length < 1) spawnPickup("health");

      for (const fl of G.floats) fl.t += dt;
      G.floats = G.floats.filter((fl) => fl.t < 2);

      scheduleMusic();
    }

    // ================================================================
    // Rendering — raycaster
    // ================================================================
    const zbuf = new Float32Array(VIEW_W);

    function renderWorld() {
      const p = G.player;
      const P = SPORTS[G.mode === "play" ? lvl().sport : LEVELS[0].sport];
      const bobOff = Math.sin(p.bob) * 6;
      const horizon = VIEW_H / 2 + bobOff;

      // ceiling
      const cg = ctx.createLinearGradient(0, 0, 0, horizon);
      cg.addColorStop(0, "#05070f");
      cg.addColorStop(1, P.ceil);
      ctx.fillStyle = cg;
      ctx.fillRect(0, 0, VIEW_W, horizon);
      // floor
      const fg = ctx.createLinearGradient(0, horizon, 0, VIEW_H);
      fg.addColorStop(0, P.floor);
      fg.addColorStop(1, "#0a0c14");
      ctx.fillStyle = fg;
      ctx.fillRect(0, horizon, VIEW_W, VIEW_H - horizon);

      const dirX = Math.cos(p.ang), dirY = Math.sin(p.ang);
      const planeLen = 0.66;
      const planeX = -dirY * planeLen, planeY = dirX * planeLen;

      const STEP = 2; // render 2px-wide columns for performance; still crisp
      for (let x = 0; x < VIEW_W; x += STEP) {
        const cameraX = (2 * x) / VIEW_W - 1;
        const rayX = dirX + planeX * cameraX;
        const rayY = dirY + planeY * cameraX;

        let mapX = p.x | 0, mapY = p.y | 0;
        const ddx = Math.abs(1 / rayX), ddy = Math.abs(1 / rayY);
        let stepX, stepY, sideX, sideY;
        if (rayX < 0) { stepX = -1; sideX = (p.x - mapX) * ddx; } else { stepX = 1; sideX = (mapX + 1 - p.x) * ddx; }
        if (rayY < 0) { stepY = -1; sideY = (p.y - mapY) * ddy; } else { stepY = 1; sideY = (mapY + 1 - p.y) * ddy; }

        let side = 0, cell = 0, guard = 0;
        while (guard++ < 64) {
          if (sideX < sideY) { sideX += ddx; mapX += stepX; side = 0; }
          else { sideY += ddy; mapY += stepY; side = 1; }
          cell = cellAt(mapX, mapY);
          if (cell) break;
        }
        const perp = side === 0 ? sideX - ddx : sideY - ddy;
        for (let s = 0; s < STEP && x + s < VIEW_W; s++) zbuf[x + s] = perp;

        const lineH = VIEW_H / perp;
        let drawStart = horizon - lineH / 2;
        let wallX = side === 0 ? p.y + perp * rayY : p.x + perp * rayX;
        wallX -= Math.floor(wallX);
        let texX = (wallX * TEX) | 0;
        if ((side === 0 && rayX > 0) || (side === 1 && rayY < 0)) texX = TEX - texX - 1;

        const tex = TEXES[cell] || TEXES[1];
        ctx.drawImage(tex, texX, 0, 1, TEX, x, drawStart, STEP, lineH);

        // shading: darker far away and on y-sides; exit gate pulses brighter
        let shade = clamp(perp / 13, 0, 0.82);
        if (side === 1) shade = Math.min(0.86, shade + 0.18);
        if (cell === 9) shade *= 0.4 + Math.abs(Math.sin(G.time * 3)) * 0.2;
        if (shade > 0.01) {
          ctx.fillStyle = `rgba(6,8,16,${shade})`;
          ctx.fillRect(x, drawStart, STEP, lineH);
        }
      }

      // ----- sprites (fans + pickups), painter's order far->near -----
      const sprites = [];
      for (const f of G.fans) sprites.push({ ent: f, kind: "fan", x: f.x, y: f.y });
      for (const it of G.pickups) sprites.push({ ent: it, kind: "pickup", x: it.x, y: it.y });
      for (const s of sprites) s.d = (s.x - p.x) ** 2 + (s.y - p.y) ** 2;
      sprites.sort((a, b) => b.d - a.d);

      const invDet = 1 / (planeX * dirY - dirX * planeY);
      for (const s of sprites) {
        const dx = s.x - p.x, dy = s.y - p.y;
        const tX = invDet * (dirY * dx - dirX * dy);
        const tY = invDet * (-planeY * dx + planeX * dy); // depth
        if (tY <= 0.2) continue;
        const screenX = (VIEW_W / 2) * (1 + tX / tY);

        let img, scaleH, anchorBottom;
        if (s.kind === "fan") {
          const f = s.ent;
          const sp = FAN_SPRITES[f.look];
          img = f.state === "happy" ? sp.happy : sp.hangry;
          scaleH = 1.0; anchorBottom = true;
        } else {
          img = PICKUP_SPRITES[s.ent.kind];
          scaleH = 0.42; anchorBottom = true;
        }
        const spriteH = Math.abs(VIEW_H / tY) * scaleH;
        const spriteW = spriteH * (img.width / img.height);
        const floatY = s.kind === "pickup" ? Math.sin(s.ent.t * 3) * spriteH * 0.06 : 0;
        // feet sit on the floor line for this depth
        const groundY = horizon + (VIEW_H / tY) / 2;
        const drawStartY = (anchorBottom ? groundY - spriteH : horizon - spriteH / 2) + floatY;
        const startX = Math.floor(screenX - spriteW / 2);
        const flash = s.kind === "fan" && s.ent.flash;

        for (let col = 0; col < spriteW; col++) {
          const sx = startX + col;
          if (sx < 0 || sx >= VIEW_W) continue;
          if (tY >= zbuf[sx]) continue; // occluded by wall
          const texCol = Math.floor((col / spriteW) * img.width);
          ctx.drawImage(img, texCol, 0, 1, img.height, sx, drawStartY, 1, spriteH);
          // hit-flash: additively redraw the slice so only the sprite's own
          // (non-transparent) pixels brighten — leaving walls/floor untouched
          if (flash) {
            ctx.save();
            ctx.globalCompositeOperation = "lighter";
            ctx.globalAlpha = 0.6;
            ctx.drawImage(img, texCol, 0, 1, img.height, sx, drawStartY, 1, spriteH);
            ctx.restore();
          }
        }
      }

      // weapon viewmodel + muzzle/serve flash + hurt vignette
      drawViewmodel(bobOff);
      if (p.hurt > 0.02) {
        ctx.fillStyle = `rgba(207,35,80,${p.hurt * 0.42})`;
        ctx.fillRect(0, 0, VIEW_W, VIEW_H);
      }
    }

    // First-person "snack server" weapon at the bottom of the view.
    function drawViewmodel(bobOff) {
      const p = G.player;
      const cx = VIEW_W / 2 + Math.sin(p.bob) * 10;
      const baseY = VIEW_H + 6 + p.recoil * 26 + Math.abs(Math.sin(p.bob)) * 6;
      ctx.save();
      // forearm + glove
      ctx.fillStyle = "#b97a4e";
      ctx.beginPath();
      ctx.moveTo(cx - 60, VIEW_H);
      ctx.lineTo(cx + 60, VIEW_H);
      ctx.lineTo(cx + 40, baseY - 70);
      ctx.lineTo(cx - 40, baseY - 70);
      ctx.closePath(); ctx.fill();
      // Juma apron cuff
      ctx.fillStyle = "#e33a5e";
      ctx.fillRect(cx - 52, baseY - 64, 104, 16);
      ctx.fillStyle = "#fdbf51";
      ctx.font = "800 13px 'Montserrat Variable', sans-serif";
      ctx.textAlign = "center";
      ctx.fillText("JUMA", cx, baseY - 52);
      // serving tray
      ctx.fillStyle = "#caa15f";
      ctx.beginPath(); ctx.roundRect(cx - 70, baseY - 92, 140, 22, 8); ctx.fill();
      ctx.fillStyle = "#8a5e2c";
      ctx.fillRect(cx - 70, baseY - 74, 140, 6);
      // a snack ready on the tray
      const snack = (G.mode === "play" ? lvl().menu : ["hotdog"])[0];
      drawSnackIcon(ctx, snack, cx, baseY - 96, 0.95);
      ctx.restore();
      // muzzle / serve flash (a snack flying out)
      if (p.muzzle > 0.05) {
        ctx.save();
        ctx.globalAlpha = p.muzzle;
        ctx.fillStyle = "#fff6d8";
        ctx.beginPath(); ctx.arc(cx, baseY - 120, 16 + p.muzzle * 16, 0, 7); ctx.fill();
        ctx.fillStyle = "#fdbf51";
        ctx.beginPath(); ctx.arc(cx, baseY - 120, 8 + p.muzzle * 8, 0, 7); ctx.fill();
        ctx.restore();
      }
    }

    // small snack glyph used on the tray and HUD
    function drawSnackIcon(c, type, x, y, s) {
      c.save(); c.translate(x, y); c.scale(s, s); c.lineCap = "round";
      const RR = (px, py, w, h, r) => { c.beginPath(); c.roundRect(px, py, w, h, r); };
      if (type === "hotdog") {
        c.fillStyle = "#e8b06b"; c.beginPath(); c.ellipse(0, 4, 17, 7, 0, 0, 7); c.fill();
        c.fillStyle = "#c4502e"; RR(-18, -6, 36, 9, 5); c.fill();
        c.strokeStyle = "#f7c948"; c.lineWidth = 2;
        c.beginPath(); c.moveTo(-13, -2); for (let i = 0; i < 5; i++) c.lineTo(-13 + (i + 0.5) * 5.2, i % 2 ? -2 : -6); c.stroke();
      } else if (type === "soda") {
        c.fillStyle = "#f4f4f6"; c.beginPath(); c.moveTo(-10, -8); c.lineTo(10, -8); c.lineTo(7, 14); c.lineTo(-7, 14); c.closePath(); c.fill();
        c.fillStyle = "#e33a5e"; c.beginPath(); c.moveTo(-9.4, -3); c.lineTo(9.4, -3); c.lineTo(8.6, 3); c.lineTo(-8.6, 3); c.closePath(); c.fill();
        c.fillStyle = "#c9cdd6"; RR(-11, -11, 22, 4, 2); c.fill();
        c.strokeStyle = "#e33a5e"; c.lineWidth = 2.5; c.beginPath(); c.moveTo(2, -11); c.lineTo(7, -20); c.stroke();
      } else if (type === "popcorn") {
        c.fillStyle = "#d94f4f"; c.beginPath(); c.moveTo(-11, -4); c.lineTo(11, -4); c.lineTo(8, 14); c.lineTo(-8, 14); c.closePath(); c.fill();
        c.fillStyle = "#ffffff"; for (let i = -1; i <= 1; i++) c.fillRect(i * 6 - 1.5, -4, 3, 17);
        c.fillStyle = "#fff3d0"; [[-7, -8], [0, -11], [7, -8], [-3, -6], [4, -5]].forEach(([px, py]) => { c.beginPath(); c.arc(px, py, 4.2, 0, 7); c.fill(); });
      } else if (type === "pretzel") {
        c.strokeStyle = "#a9683a"; c.lineWidth = 6;
        c.beginPath(); c.arc(0, 0, 11, 0.6, Math.PI * 2 + 0.5); c.stroke();
        c.beginPath(); c.moveTo(-8, -6); c.quadraticCurveTo(0, 4, 8, 12); c.stroke();
        c.beginPath(); c.moveTo(8, -6); c.quadraticCurveTo(0, 4, -8, 12); c.stroke();
      } else if (type === "nachos") {
        c.fillStyle = "#c2483e"; c.beginPath(); c.moveTo(-13, 2); c.lineTo(13, 2); c.lineTo(9, 14); c.lineTo(-9, 14); c.closePath(); c.fill();
        c.fillStyle = "#f2c14e"; [[-8, 2, -14, -12, -2], [0, 2, -6, -14, 6], [8, 2, 2, -11, 14]].forEach(([ax, ay, bx, by, cx2]) => { c.beginPath(); c.moveTo(ax, ay); c.lineTo(bx, by); c.lineTo(cx2, ay); c.closePath(); c.fill(); });
      } else {
        c.fillStyle = "#f4f4f6"; RR(-9, -8, 18, 22, 3); c.fill();
        c.fillStyle = "#2f9e6e"; c.fillRect(-9, -1, 18, 8);
        c.fillStyle = "#c9cdd6"; RR(-10.5, -11, 21, 4, 2); c.fill();
      }
      c.restore();
    }

    // ---------- HUD (Doom-style status bar) ----------
    function drawCrewFace(x, y, r) {
      const hp = G.health;
      const hurt = G.player.hurt;
      ctx.save();
      ctx.translate(x, y);
      // helmet/cap
      ctx.fillStyle = "#b97a4e"; ctx.beginPath(); ctx.arc(0, 2, r, 0, 7); ctx.fill();
      ctx.fillStyle = "#e33a5e"; ctx.beginPath(); ctx.arc(0, -2, r, Math.PI, 0); ctx.fill();
      ctx.beginPath(); ctx.roundRect(0, -6, r + 6, 5, 2); ctx.fill();
      ctx.fillStyle = "#fff"; ctx.font = "800 8px sans-serif"; ctx.textAlign = "center"; ctx.fillText("J", 0, -5);
      // eyes
      ctx.fillStyle = "#1d1d24";
      ctx.beginPath(); ctx.arc(-r * 0.35, 1, 2, 0, 7); ctx.fill();
      ctx.beginPath(); ctx.arc(r * 0.35, 1, 2, 0, 7); ctx.fill();
      // mouth by health
      ctx.strokeStyle = "#1d1d24"; ctx.lineWidth = 2;
      ctx.beginPath();
      if (hurt > 0.3) { ctx.arc(0, r * 0.55, 3, 0, Math.PI * 2); }
      else if (hp > 66) { ctx.arc(0, r * 0.3, 4, 0.1, Math.PI - 0.1); }
      else if (hp > 33) { ctx.moveTo(-4, r * 0.55); ctx.lineTo(4, r * 0.55); }
      else { ctx.arc(0, r * 0.7, 4, Math.PI + 0.1, -0.1); }
      ctx.stroke();
      // sweat when low
      if (hp <= 40) { ctx.fillStyle = "#8fd8f5"; ctx.beginPath(); ctx.arc(-r * 0.7, -2, 2.4, 0, 7); ctx.fill(); }
      ctx.restore();
    }

    function drawHUD() {
      const y0 = VIEW_H;
      const L = lvl();
      // bar background
      ctx.fillStyle = "#0c0e1c";
      ctx.fillRect(0, y0, W, HUD_H);
      ctx.fillStyle = "#fdbf51";
      ctx.fillRect(0, y0, W, 3);

      const pad = 22, midY = y0 + HUD_H / 2;

      // segment helper
      const seg = (cx, label, value, color) => {
        ctx.textAlign = "center";
        ctx.fillStyle = "#9ba3c9";
        ctx.font = "700 11px 'Plus Jakarta Sans Variable', sans-serif";
        ctx.fillText(label, cx, y0 + 30);
        ctx.fillStyle = color;
        ctx.font = "800 30px 'Montserrat Variable', sans-serif";
        ctx.fillText(value, cx, y0 + 64);
      };

      // venue / role (left)
      ctx.textAlign = "left";
      ctx.fillStyle = "#fdbf51";
      ctx.font = "800 15px 'Montserrat Variable', sans-serif";
      ctx.fillText(L.venue.toUpperCase(), pad, y0 + 34);
      ctx.fillStyle = "#9ba3c9";
      ctx.font = "600 11px 'Plus Jakarta Sans Variable', sans-serif";
      ctx.fillText(`${L.role} · ${L.city} · Shift ${G.level + 1}/4`, pad, y0 + 52);

      // crew face
      drawCrewFace(pad + 26, y0 + 86, 16);
      ctx.textAlign = "left";
      ctx.fillStyle = "#fff";
      ctx.font = "800 14px 'Montserrat Variable', sans-serif";

      // patience (health)
      const hcol = G.health > 50 ? "#7ee0a8" : G.health > 25 ? "#fdbf51" : "#ff6b8a";
      seg(W * 0.42, "PATIENCE", Math.round(G.health) + "%", hcol);
      // snacks (ammo)
      seg(W * 0.58, "SNACKS", String(G.ammo), G.ammo > 0 ? "#9bdbf3" : "#ff6b8a");
      // tips earned
      seg(W * 0.73, "TIPS", money(G.earned), "#fdbf51");

      // served / quota + gate state (right)
      ctx.textAlign = "right";
      ctx.fillStyle = "#9ba3c9";
      ctx.font = "700 11px 'Plus Jakarta Sans Variable', sans-serif";
      ctx.fillText("SERVED", W - pad, y0 + 30);
      ctx.fillStyle = "#fff";
      ctx.font = "800 24px 'Montserrat Variable', sans-serif";
      ctx.fillText(`${G.sServed}/${L.quota}`, W - pad, y0 + 56);
      ctx.font = "800 11px 'Montserrat Variable', sans-serif";
      if (G.exitOpen) {
        ctx.fillStyle = Math.sin(G.time * 6) > 0 ? "#7ee0a8" : "#9bdbf3";
        ctx.fillText("CLOCK-OUT OPEN ▸", W - pad, y0 + 78);
      } else {
        ctx.fillStyle = "#9ba3c9";
        ctx.fillText(`SERVE ${Math.max(0, L.quota - G.sServed)} MORE`, W - pad, y0 + 78);
      }

      // floating messages stacked just above the HUD
      ctx.textAlign = "center";
      G.floats.forEach((fl, i) => {
        ctx.globalAlpha = clamp(2 - fl.t, 0, 1) * clamp(fl.t * 4, 0, 1);
        ctx.fillStyle = fl.color;
        ctx.font = "800 18px 'Montserrat Variable', sans-serif";
        ctx.fillText(fl.text, W / 2, y0 - 26 - i * 26 - fl.t * 14);
      });
      ctx.globalAlpha = 1;
    }

    // ---------- minimap (top-right of the 3D view) ----------
    function drawMinimap() {
      if (!G.map) return;
      const cell = 7, mw = G.mapW * cell, mh = G.mapH * cell;
      const ox = VIEW_W - mw - 14, oy = 14;
      ctx.save();
      ctx.globalAlpha = 0.82;
      ctx.fillStyle = "#0a0c18";
      ctx.fillRect(ox - 3, oy - 3, mw + 6, mh + 6);
      for (let y = 0; y < G.mapH; y++) for (let x = 0; x < G.mapW; x++) {
        const c = G.map[y][x];
        if (c === 0) continue;
        ctx.fillStyle = c === 9 ? (G.exitOpen ? "#7ee0a8" : "#3a5a48") : c === 5 || c === 6 ? "#e33a5e" : "#4d588f";
        ctx.fillRect(ox + x * cell, oy + y * cell, cell - 1, cell - 1);
      }
      // fans
      for (const f of G.fans) if (f.state === "hangry") {
        ctx.fillStyle = "#ff6b8a";
        ctx.fillRect(ox + f.x * cell - 1.5, oy + f.y * cell - 1.5, 3, 3);
      }
      // player + facing
      const p = G.player;
      ctx.fillStyle = "#fdbf51";
      ctx.beginPath(); ctx.arc(ox + p.x * cell, oy + p.y * cell, 3, 0, 7); ctx.fill();
      ctx.strokeStyle = "#fdbf51"; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(ox + p.x * cell, oy + p.y * cell);
      ctx.lineTo(ox + (p.x + Math.cos(p.ang) * 1.4) * cell, oy + (p.y + Math.sin(p.ang) * 1.4) * cell); ctx.stroke();
      ctx.restore();
    }

    function render() {
      ctx.save();
      if (G.shake > 0) ctx.translate(rand(-1, 1) * G.shake * 9, rand(-1, 1) * G.shake * 9);
      renderWorld();
      ctx.restore();
      if (G.mode === "play") { drawHUD(); drawMinimap(); }
    }

    // ---------- main loop ----------
    let lastT = 0;
    function frame(t) {
      requestAnimationFrame(frame);
      const dt = Math.min(0.05, (t - lastT) / 1000 || 0);
      lastT = t;
      if (G.mode === "off") return;
      update(dt);
      render();
    }
    requestAnimationFrame(frame);

    // ================================================================
    // Flow (DOM screens)
    // ================================================================
    const stage = $("#g-stage");
    const controls = $("#g-controls");
    function show(name) {
      root.querySelectorAll("[data-screen]").forEach((el) => { el.hidden = el.dataset.screen !== name; });
      const onStage = name === "stage";
      stage.classList.toggle("hidden", !onStage);
      $("#g-title-overlay").classList.toggle("hidden", !(onStage && G.mode === "attract"));
      controls.classList.toggle("hidden", !(onStage && G.mode === "play"));
      controls.classList.toggle("flex", onStage && G.mode === "play");
    }

    function freshRun() {
      Object.assign(G, {
        level: 0, earned: 0, fund: 0, match: 0, matchRate: 0.25,
        served: 0, missed: 0, streak: 0, bestStreak: 0,
        quizAsked: [], quizRight: 0, badges: new Set(),
      });
    }

    function showIntro() {
      const L = lvl();
      $("#g-intro-kicker").textContent = `Shift ${G.level + 1} of ${LEVELS.length} · ${L.city}`;
      $("#g-intro-role").textContent = G.level === 0 ? `You're hired: ${L.role}` : `Promoted: ${L.role}!`;
      $("#g-intro-venue").textContent = `${L.venue} · ${L.city}`;
      $("#g-intro-blurb").textContent = L.blurb;
      $("#g-intro-menu").textContent = `Serving: ${L.menu.map((m) => FOODS[m].name).join(" · ")} — calm ${L.quota} fans to open the gate`;
      if (G.level > 0) sfx.promo();
      G.mode = "off";
      show("intro");
    }

    function startShift() {
      const L = lvl();
      buildTextures(L.sport);
      buildFanSprites();
      buildPickupSprites();
      buildMap(L);
      Object.assign(G, {
        mode: "play", paused: false,
        sServed: 0, sEarned: 0, shiftDmg: 0, exitOpen: false, spawnIn: 0.8, spawnedTotal: 0,
        health: 100, ammo: 22,
        fans: [], pickups: [], floats: [], shake: 0, streak: 0,
      });
      const [sx, sy, sa] = L.start;
      G.player.x = sx + 0.5; G.player.y = sy + 0.5; G.player.ang = sa;
      G.player.bob = 0; G.player.cooldown = 0; G.player.recoil = 0; G.player.muzzle = 0; G.player.hurt = 0;
      // a couple of starter pickups
      spawnPickup("ammo");
      show("stage");
      musicTimer = 0;
      scheduleMusic();
    }

    function endShift(success) {
      G.mode = "off";
      sfx.whistle();
      if (G.shiftDmg === 0 && G.sServed >= 3) G.badges.add("perfect");
      if (success && G.health >= 90) G.badges.add("crowd");
      G.lastShiftSuccess = success;
      showLearn(success);
    }

    function showLearn(success) {
      const L = lvl();
      $("#g-sum-title").textContent = success ? `Clocked out at ${L.venue}!` : `Sent home early at ${L.venue}`;
      const stats = [
        ["Fans served", G.sServed],
        ["Patience left", Math.round(G.health) + "%"],
        ["Shift earnings", money(G.sEarned)],
        ["Best streak", "×" + G.bestStreak],
      ];
      $("#g-sum-stats").innerHTML = stats
        .map(([k, v]) => `
        <div class="rounded-xl bg-white/[0.07] p-3 text-center ring-1 ring-white/10">
          <dt class="text-[0.6rem] font-bold uppercase tracking-wider text-navy-300">${k}</dt>
          <dd class="mt-1 font-heading text-xl font-extrabold text-white">${v}</dd>
        </div>`).join("");

      let qi = randInt(0, QUIZ.length - 1);
      while (G.quizAsked.includes(qi)) qi = (qi + 1) % QUIZ.length;
      G.quizAsked.push(qi);
      const Q = QUIZ[qi];
      $("#g-quiz-q").textContent = Q.q;
      const opts = $("#g-quiz-opts");
      $("#g-quiz-result").classList.add("hidden");
      $("#g-learn-next").classList.add("hidden");
      opts.innerHTML = "";
      Q.opts.forEach((opt, i) => {
        const b = document.createElement("button");
        b.className = "rounded-xl bg-white/10 px-4 py-3 text-left text-sm font-semibold text-white ring-1 ring-white/15 transition hover:bg-white/20";
        b.textContent = opt;
        b.addEventListener("click", () => answerQuiz(Q, i, b, opts));
        opts.appendChild(b);
      });
      show("learn");
    }

    function answerQuiz(Q, i, btn, opts) {
      [...opts.children].forEach((b, j) => {
        b.disabled = true;
        b.classList.remove("hover:bg-white/20");
        if (j === Q.a) b.classList.add("!bg-emerald-500/30", "!ring-emerald-300/60");
      });
      const correct = i === Q.a;
      if (correct) { G.quizRight++; G.matchRate = Math.min(1, G.matchRate + 0.25); sfx.right(); }
      else { btn.classList.add("!bg-brand-600/40", "!ring-brand-400/60"); sfx.wrong(); }
      const matchAmt = G.sEarned * SAVE_RATE * G.matchRate;
      G.match += matchAmt;
      const result = $("#g-quiz-result");
      result.className = `mt-4 rounded-xl p-4 text-sm leading-relaxed ring-1 ${correct ? "bg-emerald-500/15 ring-emerald-300/40 text-emerald-100" : "bg-brand-600/20 ring-brand-400/40 text-navy-100"}`;
      result.innerHTML = `<strong>${correct ? "Correct!" : "Not quite."}</strong> ${Q.why}<br/><span class="mt-2 inline-block font-heading font-bold text-sky">Juma matched ${Math.round(G.matchRate * 100)}% of this shift's savings: +${money(matchAmt)}</span>`;
      result.classList.remove("hidden");

      const next = $("#g-learn-next");
      next.textContent = G.level + 1 < LEVELS.length ? `Next stop: ${LEVELS[G.level + 1].city} →` : "See season results";
      next.classList.remove("hidden");
    }

    function showFinal() {
      G.badges.add("season");
      if (G.quizRight === LEVELS.length) G.badges.add("smart");
      const ratio = G.served / Math.max(1, G.served + G.missed);
      const stars = Math.max(1, Math.min(5, Math.round((clamp(G.served / 30, 0, 1) * 0.7 + (G.quizRight / LEVELS.length) * 0.3) * 5)));
      $("#g-final-stars").textContent = "★".repeat(stars) + "☆".repeat(5 - stars);
      $("#g-final-stars").style.color = "#fdbf51";
      $("#g-final-earned").textContent = money(G.earned);
      $("#g-final-saved").textContent = money(G.fund);
      $("#g-final-match").textContent = "+" + money(G.match);
      const score = Math.round(G.earned + G.match);
      $("#g-final-score").textContent = money(score);
      $("#g-final-line").textContent = `You served ${G.served} fans across 4 cities and answered ${G.quizRight}/4 Money Minutes correctly.`;

      $("#g-badges").innerHTML = BADGES.map((b) => {
        const got = G.badges.has(b.id);
        return `<span title="${b.desc}" class="inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 font-heading text-xs font-bold ${got ? "bg-gold/20 text-gold ring-1 ring-gold/40" : "bg-white/5 text-white/30 ring-1 ring-white/10"}">${got ? "●" : "○"} ${b.name}</span>`;
      }).join("");

      let best = 0;
      try { best = JSON.parse(localStorage.getItem(BEST_KEY) || "{}").score || 0; } catch {}
      const newBest = score > best;
      $("#g-final-newbest").classList.toggle("hidden", !newBest);
      if (newBest) localStorage.setItem(BEST_KEY, JSON.stringify({ score, date: Date.now() }));
      sfx.promo();
      G.mode = "off";
      show("final");
    }

    // ---------- pause / quit / mute ----------
    function setPaused(pp) {
      if (G.mode !== "play") return;
      G.paused = pp;
      $("#g-pause-overlay").classList.toggle("hidden", !pp);
      $("#g-pause-overlay").classList.toggle("flex", pp);
      if (!pp) { musicTimer = 0; scheduleMusic(); }
    }

    function toTitle() {
      G.mode = "attract";
      buildTextures(LEVELS[0].sport);
      buildFanSprites();
      buildPickupSprites();
      buildMap(LEVELS[0]);
      G.player.x = G.mapW / 2; G.player.y = G.mapH / 2; G.player.ang = 0; G.player.bob = 0;
      G.fans = []; G.pickups = []; G.floats = [];
      for (let i = 0; i < 5; i++) spawnFan();
      $("#g-pause-overlay").classList.add("hidden");
      $("#g-pause-overlay").classList.remove("flex");
      refreshBest();
      show("stage");
    }

    function refreshBest() {
      let best = null;
      try { best = JSON.parse(localStorage.getItem(BEST_KEY) || "null"); } catch {}
      const el = $("#g-best");
      if (best && best.score) { el.textContent = `Your best season: ${money(best.score)}`; el.classList.remove("hidden"); }
    }

    function updateMuteBtn() {
      $("#g-mute").textContent = muted ? "♪̸" : "♪";
      $("#g-mute").setAttribute("aria-label", muted ? "Unmute sound" : "Mute sound");
    }

    // ================================================================
    // Input
    // ================================================================
    $("#g-start").addEventListener("click", () => { freshRun(); showIntro(); });
    $("#g-howto-btn").addEventListener("click", () => { G.mode = "off"; show("howto"); });
    $("#g-howto-back").addEventListener("click", toTitle);
    $("#g-shift-go").addEventListener("click", startShift);
    $("#g-learn-next").addEventListener("click", () => {
      G.level++;
      if (G.level < LEVELS.length) showIntro();
      else showFinal();
    });
    $("#g-again").addEventListener("click", () => { freshRun(); showIntro(); });
    $("#g-serve").addEventListener("click", serve);
    $("#g-pause").addEventListener("click", () => setPaused(true));
    $("#g-resume").addEventListener("click", () => setPaused(false));
    $("#g-quit").addEventListener("click", () => { if (confirm("Quit this shift? Your season progress will be lost.")) toTitle(); });
    $("#g-mute").addEventListener("click", () => {
      muted = !muted;
      localStorage.setItem("jumaConcourseMuted", muted ? "1" : "0");
      updateMuteBtn();
      if (!muted) { musicTimer = 0; scheduleMusic(); }
    });

    // touch movement pad (press-and-hold)
    const HOLD_MAP = { turnL: "turnL", turnR: "turnR", fwd: "fwd", back: "back" };
    document.querySelectorAll("#g-touch [data-hold]").forEach((btn) => {
      const k = HOLD_MAP[btn.dataset.hold];
      const on = (e) => { e.preventDefault(); keys[k] = true; };
      const off = (e) => { e.preventDefault(); keys[k] = false; };
      btn.addEventListener("pointerdown", on);
      btn.addEventListener("pointerup", off);
      btn.addEventListener("pointerleave", off);
      btn.addEventListener("pointercancel", off);
    });

    document.addEventListener("keydown", (e) => {
      if (G.mode !== "play") return;
      const k = e.key.toLowerCase();
      if (["arrowup", "arrowdown", "arrowleft", "arrowright", " ", "spacebar"].includes(k)) e.preventDefault();
      if (k === "w" || k === "arrowup") keys.fwd = true;
      else if (k === "s" || k === "arrowdown") keys.back = true;
      else if (k === "a") keys.left = true;
      else if (k === "d") keys.right = true;
      else if (k === "arrowleft") keys.turnL = true;
      else if (k === "arrowright") keys.turnR = true;
      else if (k === " " || k === "enter") serve();
      else if (k === "p") setPaused(!G.paused);
      else if (k === "m") $("#g-mute").click();
    });
    document.addEventListener("keyup", (e) => {
      const k = e.key.toLowerCase();
      if (k === "w" || k === "arrowup") keys.fwd = false;
      else if (k === "s" || k === "arrowdown") keys.back = false;
      else if (k === "a") keys.left = false;
      else if (k === "d") keys.right = false;
      else if (k === "arrowleft") keys.turnL = false;
      else if (k === "arrowright") keys.turnR = false;
    });

    // mouse look (pointer lock) + click to serve
    canvas.addEventListener("click", () => {
      if (G.mode !== "play" || G.paused) return;
      if (document.pointerLockElement !== canvas) { try { canvas.requestPointerLock(); } catch {} }
      else serve();
    });
    document.addEventListener("mousemove", (e) => {
      if (document.pointerLockElement === canvas && G.mode === "play" && !G.paused) {
        G.player.ang += e.movementX * 0.0024;
      }
    });

    document.addEventListener("visibilitychange", () => { if (document.hidden && G.mode === "play") setPaused(true); });

    // expose for automated testing / debugging
    window.__GD = G;
    window.__GDapi = { serve, startShift, lvl: () => lvl(), spawnFan, openExit };

    updateMuteBtn();
    toTitle();
  }
</script>
