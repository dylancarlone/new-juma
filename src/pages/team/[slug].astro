---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Media from "@/components/Media.astro";
import CTABanner from "@/components/sections/CTABanner.astro";

export async function getStaticPaths() {
  const team = await getCollection("team");
  return team.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={`${d.name} — ${d.role}`} description={`${d.name}, ${d.role} at Juma Ventures.`}>
  <Container size="narrow" class="py-14 md:py-20">
    <a href="/leadership/" class="font-semibold text-brand-600 hover:underline">← Back to Leadership</a>
    <div class="mt-8 grid gap-8 sm:grid-cols-[200px_1fr] sm:items-start">
      <div class="overflow-hidden rounded-2xl bg-cream shadow-[var(--shadow-card)]">
        <Media src={d.photo} alt={d.name} class="aspect-square w-full" fit="cover" loading="eager" />
      </div>
      <div>
        <h1 class="text-3xl md:text-4xl">{d.name}</h1>
        <p class="mt-1 text-lg font-semibold text-brand-600">{d.role}</p>
        {d.email && <p class="mt-2"><a href={`mailto:${d.email}`} class="text-navy-700 hover:underline">{d.email}</a></p>}
      </div>
    </div>
    <div class="prose-juma mt-10"><Content /></div>
  </Container>
  <CTABanner />
</BaseLayout>
