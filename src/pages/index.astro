---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Pillars from "@/components/sections/Pillars.astro";
import CTABanner from "@/components/sections/CTABanner.astro";
import PostCard from "@/components/cards/PostCard.astro";
import Media from "@/components/Media.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/Icon.astro";
import { getFeedPosts, postPath } from "@/lib/content";
import home from "@/data/home.json";

const slugFor: Record<string, string> = {
  "San Francisco": "san-francisco",
  "San Francisco / Bay Area": "san-francisco",
  Sacramento: "sacramento",
  Seattle: "seattle",
  "San Jose": "san-jose",
};

const recent = (await getFeedPosts()).slice(0, 3);

// Split the hero heading so its closing phrase gets the gold marker treatment.
const heading = home.hero.heading;
const highlight = "the potential of young people";
const hasHighlight = heading.toLowerCase().includes(highlight);
const headingLead = hasHighlight ? heading.slice(0, heading.toLowerCase().indexOf(highlight)) : heading;
const headingMark = hasHighlight ? heading.slice(heading.toLowerCase().indexOf(highlight)) : "";
---

<BaseLayout description={home.hero.subheading}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy-950 text-white">
    <div class="absolute inset-0">
      <Media src={home.hero.image} alt="" class="h-full w-full" loading="eager" fit="cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/75 to-navy-900/30"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-transparent to-navy-950/40"></div>
    </div>
    <div class="absolute inset-0 bg-dots-light opacity-40" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -right-40 -top-40 h-[34rem] w-[34rem] rounded-full bg-brand-500/20 blur-[130px]" aria-hidden="true"></div>

    <Container class="relative pb-40 pt-24 md:pb-48 md:pt-36">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow text-gold">Est. 1993 · A nonprofit social enterprise</p>
        <h1 class="mt-5 text-4xl text-white sm:text-5xl md:text-6xl lg:text-[4.5rem]">
          {headingLead}{hasHighlight && <span class="mark-brand whitespace-pre-wrap">{headingMark}</span>}
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-relaxed text-navy-100 md:text-xl">{home.hero.subheading}</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="/donate/" variant="brand" size="lg" arrow>Donate</Button>
          <Button href="/programs/" variant="white" size="lg">Our Programs</Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Impact stats — overlapping the hero -->
  {
    home.stats?.length > 0 && (
      <section class="relative z-10 -mt-24 md:-mt-28" aria-label="Juma impact">
        <Container>
          <dl class="grid grid-cols-2 overflow-hidden rounded-[var(--radius-card)] bg-white shadow-[var(--shadow-lift)] ring-1 ring-navy-100 lg:grid-cols-4" data-reveal>
            {home.stats.map((s, i) => (
              <div class:list={["px-6 py-8 text-center md:py-10", i > 0 && "border-navy-100 max-lg:[&:nth-child(even)]:border-l lg:border-l", i >= 2 && "max-lg:border-t"]}>
                <dt class="bg-gradient-to-br from-brand-600 to-accent bg-clip-text font-heading text-4xl font-extrabold tracking-tight text-transparent md:text-5xl">{s.value}</dt>
                <dd class="mx-auto mt-2.5 max-w-[12rem] text-xs font-bold uppercase tracking-wider text-warmgray md:text-sm">{s.label}</dd>
              </div>
            ))}
          </dl>
        </Container>
      </section>
    )
  }

  <Pillars heading="How Juma Works" intro="A proven Earn, Learn, Connect model that turns a first job into a lasting career path." pillars={home.pillars} />

  <!-- Locations -->
  <section class="relative overflow-hidden bg-cream">
    <div class="absolute inset-0 bg-dots-dark opacity-50" aria-hidden="true"></div>
    <Container class="relative py-20 md:py-28">
      <div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
        <p class="eyebrow eyebrow-center justify-center text-brand-600">Where we work</p>
        <h2 class="mt-3 text-3xl md:text-5xl">{home.locationsHeading ?? "Four Communities. One Mission."}</h2>
        {home.locationsIntro && <p class="mt-5 text-lg text-ink-soft">{home.locationsIntro}</p>}
      </div>
      <div class="grid grid-cols-2 gap-5 lg:grid-cols-4">
        {
          home.locations?.map((loc, i) => {
            const slug = slugFor[loc.name] ?? slugFor[loc.name.split(" /")[0]];
            return (
              <a
                href={`/${slug}/`}
                class="card-lift group relative flex aspect-[3/4] items-end overflow-hidden rounded-[var(--radius-card)] bg-navy-900 shadow-[var(--shadow-card)]"
                data-reveal
                style={`--reveal-delay: ${i * 100}ms`}
              >
                <Media src={loc.image} alt={loc.name} class="absolute inset-0 h-full w-full transition duration-700 group-hover:scale-[1.06]" fit="cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-navy-950/95 via-navy-900/30 to-transparent" />
                <div class="relative w-full p-5">
                  <p class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-gold">
                    <Icon name="mapPin" size={13} />
                    Juma
                  </p>
                  <h3 class="mt-1 flex items-center justify-between gap-2 font-heading text-xl font-extrabold text-white">
                    {loc.name}
                    <Icon name="arrowRight" size={18} class="shrink-0 -translate-x-1 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100" />
                  </h3>
                </div>
              </a>
            );
          })
        }
      </div>
    </Container>
  </section>

  <!-- Youth Voices -->
  {
    home.testimonials?.length > 0 && (
      <section class="relative overflow-hidden bg-gradient-to-br from-navy-950 via-navy-900 to-navy-800 text-white">
        <div class="absolute inset-0 bg-dots-light opacity-30" aria-hidden="true" />
        <div class="pointer-events-none absolute -left-32 top-0 h-96 w-96 rounded-full bg-brand-500/15 blur-[110px]" aria-hidden="true" />
        <div class="pointer-events-none absolute -bottom-24 -right-24 h-80 w-80 rounded-full bg-gold/10 blur-[100px]" aria-hidden="true" />
        <Container class="relative py-20 md:py-28">
          <div class="mb-14 text-center" data-reveal>
            <p class="eyebrow eyebrow-center justify-center text-gold">Youth Voices</p>
            <h2 class="mt-3 text-3xl text-white md:text-5xl">In their own words</h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            {home.testimonials.map((t, i) => (
              <figure
                class="flex h-full flex-col rounded-[var(--radius-card)] bg-gradient-to-b from-white/[0.09] to-white/[0.04] p-7 ring-1 ring-white/10 transition-all duration-300 hover:-translate-y-1.5 hover:ring-gold/40"
                data-reveal
                style={`--reveal-delay: ${i * 100}ms`}
              >
                <span class="font-heading text-6xl font-extrabold leading-none text-gold" aria-hidden="true">“</span>
                <blockquote class="-mt-4 flex-1 leading-relaxed text-navy-100">{t.quote}</blockquote>
                <figcaption class="mt-5 border-t border-white/10 pt-4 font-heading font-bold text-gold">
                  {t.name}
                  {t.role && <span class="mt-0.5 block text-xs font-semibold uppercase tracking-wider text-navy-300">{t.role}</span>}
                </figcaption>
              </figure>
            ))}
          </div>
          <div class="mt-12 text-center" data-reveal>
            <Button href="/stories/" variant="brand" size="lg" arrow>Read youth stories</Button>
          </div>
        </Container>
      </section>
    )
  }

  <!-- Recent news -->
  {
    recent.length > 0 && (
      <section class="bg-white">
        <Container class="py-20 md:py-28">
          <div class="mb-12 flex items-end justify-between" data-reveal>
            <div>
              <p class="eyebrow text-brand-600">From the field</p>
              <h2 class="mt-3 text-3xl md:text-5xl">Latest News</h2>
            </div>
            <a href="/news/" class="link-more hidden sm:inline-flex">
              All news
              <Icon name="arrowRight" size={15} />
            </a>
          </div>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {recent.map((p, i) => (
              <div data-reveal style={`--reveal-delay: ${i * 100}ms`}>
                <PostCard href={postPath(p)} title={p.data.title} excerpt={p.data.excerpt} date={p.data.publishDate} image={p.data.heroImage} imageAlt={p.data.heroImageAlt} categories={p.data.categories} />
              </div>
            ))}
          </div>
          <div class="mt-10 text-center sm:hidden">
            <Button href="/news/" variant="outline" size="md">All news</Button>
          </div>
        </Container>
      </section>
    )
  }

  <CTABanner />
</BaseLayout>
