---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Hero from "@/components/sections/Hero.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/Icon.astro";
import { donate } from "@/lib/site";
---

<BaseLayout title="Donate" description="Your gift powers paid jobs, mentorship, and financial capability for opportunity youth across America.">
  <Hero
    eyebrow="Support Juma"
    heading="Invest in a young person's future."
    subheading="Every gift helps a young person earn a paycheck, build skills, and connect to a lasting career. 100% of your donation fuels opportunity for youth across our four communities."
    align="center"
  />

  <!-- Impact calculator -->
  <section class="relative overflow-hidden bg-cream">
    <div class="absolute inset-0 bg-dots-dark opacity-50" aria-hidden="true"></div>
    <Container size="narrow" class="relative py-14 md:py-16">
      <div class="rounded-[var(--radius-card)] bg-white p-6 shadow-[var(--shadow-lift)] ring-1 ring-navy-100 md:p-10" data-reveal>
        <p class="eyebrow text-brand-600">Impact calculator</p>
        <h2 class="mt-2 text-2xl md:text-3xl">What your gift makes possible</h2>

        <div class="mt-8 flex items-end justify-between gap-4">
          <p id="calc-amount" class="bg-gradient-to-br from-brand-600 to-accent bg-clip-text font-heading text-5xl font-extrabold tracking-tight text-transparent md:text-6xl">$100</p>
          <p class="pb-1.5 text-right">
            <span id="calc-hours" class="font-heading text-2xl font-extrabold text-navy-900 md:text-3xl">4</span>
            <span class="block text-xs font-bold uppercase tracking-wider text-warmgray">hours of paid, coached work</span>
          </p>
        </div>

        <input
          id="calc-slider"
          type="range"
          min="25"
          max="3000"
          step="25"
          value="100"
          class="mt-6 w-full accent-brand-500"
          aria-label="Donation amount"
        />
        <div class="mt-1 flex justify-between text-[0.65rem] font-bold uppercase tracking-wider text-navy-300">
          <span>$25</span><span>$3,000</span>
        </div>

        <!-- Progress toward one youth-year -->
        <div class="mt-7">
          <div class="mb-2 flex items-center justify-between gap-3 text-xs font-bold uppercase tracking-wider text-warmgray">
            <span>Toward one youth's average yearly earnings ($2,896)</span>
            <span id="calc-pct" class="font-heading text-brand-600">3%</span>
          </div>
          <div class="h-3.5 w-full overflow-hidden rounded-full bg-navy-50">
            <div id="calc-bar" class="h-full rounded-full bg-gradient-to-r from-brand-500 to-gold transition-all duration-300" style="width:3%"></div>
          </div>
          <p id="calc-msg" class="mt-4 rounded-xl bg-cream px-4 py-3 text-sm font-semibold text-navy-800"></p>
        </div>

        <div class="mt-7 flex flex-wrap items-center gap-4">
          <a
            id="calc-give"
            href={donate.oneTimeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group/btn inline-flex items-center gap-2 rounded-full bg-brand-500 px-9 py-4 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-600"
          >
            Give <span id="calc-give-amt">$100</span>
            <Icon name="arrowRight" size={16} class="transition-transform duration-300 group-hover/btn:translate-x-1" />
          </a>
          <p class="max-w-xs text-xs leading-relaxed text-warmgray">
            Illustrative equivalents based on Juma's 2025 program data ($1.3M in wages across 53,475 youth work hours). Gifts support the full YouthConnect program.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <Container size="narrow" class="py-14 md:py-20">
    <div class="rounded-[var(--radius-card)] border border-navy-100 bg-white p-6 shadow-[var(--shadow-card)] md:p-10">
      <!-- Frequency toggle -->
      <div class="mx-auto flex w-full max-w-xs rounded-full bg-cream p-1" role="tablist">
        <button id="tab-once" role="tab" aria-selected="true" class="freq-tab flex-1 rounded-full px-4 py-2 text-sm font-bold transition">One-time</button>
        <button id="tab-monthly" role="tab" aria-selected="false" class="freq-tab flex-1 rounded-full px-4 py-2 text-sm font-bold transition">Monthly</button>
      </div>

      <div id="panel-once" class="mt-8">
        <div class="grid grid-cols-3 gap-3 sm:grid-cols-3">
          {donate.oneTimeAmounts.map((a) => (
            <a href={donate.oneTimeUrl} target="_blank" rel="noopener noreferrer" class="rounded-2xl border-2 border-navy-200 py-4 text-center font-heading text-lg font-bold text-navy-800 transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-500 hover:bg-brand-50 hover:text-brand-600 hover:shadow-[var(--shadow-card)]">${a}</a>
          ))}
        </div>
      </div>

      <div id="panel-monthly" class="mt-8 hidden">
        <div class="grid grid-cols-3 gap-3">
          {donate.monthlyAmounts.map((a) => (
            <a href={donate.monthlyUrl} target="_blank" rel="noopener noreferrer" class="rounded-2xl border-2 border-navy-200 py-4 text-center font-heading text-lg font-bold text-navy-800 transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-500 hover:bg-brand-50 hover:text-brand-600 hover:shadow-[var(--shadow-card)]">${a}<span class="block text-xs font-medium text-warmgray">/mo</span></a>
          ))}
        </div>
      </div>

      <div class="mt-8 text-center">
        <Button href={donate.oneTimeUrl} variant="brand" size="lg" target="_blank" arrow>Donate Now</Button>
        <p class="mt-3 text-xs text-warmgray">Securely processed via {donate.provider}.</p>
      </div>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      <div class="card-lift relative overflow-hidden rounded-[var(--radius-card)] bg-cream p-6">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-400 to-gold" aria-hidden="true"></div>
        <h2 class="text-lg">Stock & cryptocurrency</h2>
        <p class="mt-2 text-sm text-ink-soft">Give appreciated stock or crypto and maximize your impact.</p>
        <a href={donate.stockCryptoUrl} target="_blank" rel="noopener noreferrer" class="link-more mt-4">Give stock or crypto <Icon name="arrowRight" size={15} /></a>
      </div>
      <div class="card-lift relative overflow-hidden rounded-[var(--radius-card)] bg-cream p-6">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-navy-500 to-sky" aria-hidden="true"></div>
        <h2 class="text-lg">Other ways to give</h2>
        <p class="mt-2 text-sm text-ink-soft">Corporate partnerships, employer matching, and planned giving.</p>
        <a href="/contact/" class="link-more mt-4">Contact our team <Icon name="arrowRight" size={15} /></a>
      </div>
    </div>
  </Container>

  <script>
    // ---------- impact calculator ----------
    // 2025 program data: $1.3M wages & stipends / 53,475 hours ≈ $24.31/hr;
    // $2,896 = average earned per youth for the year.
    const HOURLY = 1300000 / 53475;
    const YOUTH_YEAR = 2896;
    const slider = document.getElementById("calc-slider");

    function calcMsg(amt) {
      if (amt >= YOUTH_YEAR) return "A full year of average youth earnings — an entire pathway, powered by you. 🎉";
      if (amt >= 1500) return "You're most of the way to a full youth-year of earnings — transformational support.";
      if (amt >= 500) return "Weeks of paid, mentored work experience — plus the money skills to keep it.";
      if (amt >= 100) return "That's a full shift's wages — a real paycheck a young person takes home.";
      return "Every hour of paid, coached work builds a résumé and a future.";
    }

    function updateCalc() {
      const amt = Number(slider.value);
      const money = "$" + amt.toLocaleString("en-US");
      document.getElementById("calc-amount").textContent = money;
      document.getElementById("calc-give-amt").textContent = money;
      document.getElementById("calc-hours").textContent = Math.max(1, Math.round(amt / HOURLY)).toLocaleString("en-US");
      const pct = Math.min(100, Math.round((amt / YOUTH_YEAR) * 100));
      document.getElementById("calc-pct").textContent = pct + "%";
      document.getElementById("calc-bar").style.width = pct + "%";
      document.getElementById("calc-msg").textContent = calcMsg(amt);
    }
    slider?.addEventListener("input", updateCalc);
    updateCalc();

    // ---------- frequency tabs ----------
    const tabs = { once: document.getElementById("tab-once"), monthly: document.getElementById("tab-monthly") };
    const panels = { once: document.getElementById("panel-once"), monthly: document.getElementById("panel-monthly") };
    function select(key) {
      for (const k of ["once", "monthly"]) {
        const active = k === key;
        tabs[k]?.setAttribute("aria-selected", String(active));
        tabs[k]?.classList.toggle("bg-white", active);
        tabs[k]?.classList.toggle("text-brand-600", active);
        tabs[k]?.classList.toggle("shadow-sm", active);
        panels[k]?.classList.toggle("hidden", !active);
      }
    }
    tabs.once?.addEventListener("click", () => select("once"));
    tabs.monthly?.addEventListener("click", () => select("monthly"));
    select("once");
  </script>
</BaseLayout>
