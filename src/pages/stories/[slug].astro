---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Media from "@/components/Media.astro";
import CTABanner from "@/components/sections/CTABanner.astro";

export async function getStaticPaths() {
  const stories = await getCollection("story");
  return stories.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={d.title ?? `${d.name}'s Story`} description={d.pullQuote} image={d.photo ? `/media/${d.photo}` : undefined} type="article">
  {
    d.photo && (
      <section class="relative bg-navy-900 text-white">
        <Media src={d.photo} alt={d.name} class="absolute inset-0 h-full w-full opacity-40" fit="cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-navy-950 to-navy-900/40"></div>
        <Container size="narrow" class="relative py-24">
          <p class="font-heading text-sm font-bold uppercase tracking-widest text-gold">Youth Story{d.location ? ` · ${d.location}` : ""}</p>
          <h1 class="mt-3 text-4xl text-white md:text-5xl">{d.name}</h1>
          {d.pullQuote && <p class="mt-5 max-w-2xl text-xl text-navy-100">“{d.pullQuote}”</p>}
        </Container>
      </section>
    )
  }
  {
    !d.photo && (
      <section class="bg-gradient-to-br from-navy-900 to-brand-800 text-white">
        <Container size="narrow" class="py-20">
          <h1 class="text-4xl text-white md:text-5xl">{d.name}</h1>
          {d.pullQuote && <p class="mt-5 text-xl text-navy-100">“{d.pullQuote}”</p>}
        </Container>
      </section>
    )
  }

  <Container size="narrow" class="py-12">
    {d.outcome && <p class="mb-6 inline-block rounded-full bg-brand-50 px-4 py-1.5 text-sm font-semibold text-brand-700">{d.outcome}</p>}
    <div class="prose-juma"><Content /></div>
    <div class="mt-10"><a href="/stories/" class="font-semibold text-brand-600 hover:underline">← More youth stories</a></div>
  </Container>
  <CTABanner />
</BaseLayout>
