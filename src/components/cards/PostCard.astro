---
import Media from "@/components/Media.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  href: string;
  title: string;
  excerpt?: string;
  date: Date;
  image?: string;
  imageAlt?: string;
  categories?: string[];
}
const { href, title, excerpt, date, image, imageAlt, categories } = Astro.props;
const dateStr = date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<article class="card-lift group flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-navy-100 bg-white shadow-[var(--shadow-card)]">
  <a href={href} class="relative block aspect-[16/10] overflow-hidden bg-cream" tabindex="-1" aria-hidden="true">
    {
      image ? (
        <Media src={image} alt={imageAlt ?? title} class="h-full w-full transition duration-700 group-hover:scale-[1.06]" fit="cover" />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-navy-100 to-brand-100">
          <span class="font-heading text-2xl font-bold text-navy-300">Juma</span>
        </div>
      )
    }
    {
      categories && categories[0] && (
        <span class="absolute left-4 top-4 rounded-full bg-white/95 px-3.5 py-1.5 font-heading text-[0.65rem] font-bold uppercase tracking-widest text-brand-600 shadow-sm backdrop-blur">
          {categories[0]}
        </span>
      )
    }
  </a>
  <div class="flex flex-1 flex-col p-6">
    <time datetime={date.toISOString()} class="text-xs font-semibold uppercase tracking-wider text-warmgray">{dateStr}</time>
    <h3 class="mt-2 text-lg leading-snug">
      <a href={href} class="transition hover:text-brand-600">{title}</a>
    </h3>
    {excerpt && <p class="mt-2.5 line-clamp-3 text-sm leading-relaxed text-ink-soft">{excerpt}</p>}
    <a href={href} class="link-more mt-5">
      Read more
      <Icon name="arrowRight" size={15} />
    </a>
  </div>
</article>
