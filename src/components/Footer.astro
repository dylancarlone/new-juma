---
import { Image } from "astro:assets";
import logoSlogan from "@/assets/media/JUMALogoSlogan-scaled.png";
import { footerNav, social, site } from "@/lib/site";
import Icon from "@/components/Icon.astro";
import Button from "@/components/ui/Button.astro";

const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-navy-100">
  <div class="mx-auto max-w-7xl px-5 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div>
        <Image src={logoSlogan} alt="Juma Ventures" class="h-20 w-auto brightness-0 invert" loading="lazy" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-navy-200">{site.tagline}</p>
        <div class="mt-6 flex gap-3">
          {
            social.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-brand-500"
              >
                <Icon name={s.platform} size={18} />
              </a>
            ))
          }
        </div>
      </div>

      {
        footerNav.map((col) => (
          <div>
            <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-white">{col.heading}</h3>
            <ul class="mt-4 space-y-2.5">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-navy-200 transition hover:text-white">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 rounded-2xl bg-white/5 p-6 sm:flex sm:items-center sm:justify-between sm:gap-6">
      <div>
        <p class="font-heading text-lg font-bold text-white">Stay connected</p>
        <p class="mt-1 text-sm text-navy-200">Get Juma news and youth success stories in your inbox.</p>
      </div>
      <div class="mt-4 shrink-0 sm:mt-0">
        <Button href="/newsletter/" variant="brand" size="md">Join the Newsletter</Button>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-sm text-navy-300 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        <a href="/donor-privacy-policy/" class="transition hover:text-white">Privacy Policy</a>
        <a href="/financials/" class="transition hover:text-white">Financials</a>
        <a href="/contact/" class="transition hover:text-white">Contact</a>
        <span class="text-navy-400">Candid Platinum Transparency</span>
      </div>
    </div>
  </div>
</footer>
