---
import Container from "@/components/Container.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  pillars: { icon?: string; title: string; body: string }[];
  heading?: string;
  intro?: string;
}
const { pillars, heading, intro } = Astro.props;
if (!pillars?.length) return null;

// Map Juma's Earn/Learn/Connect (and similar) to icons.
const iconFor = (p: { icon?: string; title: string }) => {
  if (p.icon) return p.icon;
  const t = p.title.toLowerCase();
  if (t.includes("earn")) return "briefcase";
  if (t.includes("learn")) return "graduation";
  if (t.includes("connect")) return "link2";
  return "heart";
};
const cols = pillars.length === 3 ? "md:grid-cols-3" : pillars.length === 2 ? "md:grid-cols-2" : "md:grid-cols-2 lg:grid-cols-4";
---

<section class="bg-white">
  <Container class="py-16 md:py-24">
    {
      (heading || intro) && (
        <div class="mx-auto mb-12 max-w-2xl text-center">
          {heading && <h2 class="text-3xl md:text-4xl">{heading}</h2>}
          {intro && <p class="mt-4 text-lg text-ink-soft">{intro}</p>}
        </div>
      )
    }
    <div class={`grid grid-cols-1 gap-8 ${cols}`}>
      {
        pillars.map((p) => (
          <div class="group rounded-[var(--radius-card)] border border-navy-100 bg-white p-8 shadow-[var(--shadow-card)] transition hover:-translate-y-1 hover:shadow-[var(--shadow-lift)]">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-50 text-brand-600 transition group-hover:bg-brand-600 group-hover:text-white">
              <Icon name={iconFor(p)} size={28} />
            </div>
            <h3 class="mt-5 text-xl">{p.title}</h3>
            <p class="mt-3 leading-relaxed text-ink-soft">{p.body}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
