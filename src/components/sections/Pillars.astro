---
import Container from "@/components/Container.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  pillars: { icon?: string; title: string; body: string }[];
  heading?: string;
  intro?: string;
}
const { pillars, heading, intro } = Astro.props;
if (!pillars?.length) return null;

// Map Juma's Earn/Learn/Connect (and similar) to icons.
const iconFor = (p: { icon?: string; title: string }) => {
  if (p.icon) return p.icon;
  const t = p.title.toLowerCase();
  if (t.includes("earn")) return "briefcase";
  if (t.includes("learn")) return "graduation";
  if (t.includes("connect")) return "link2";
  return "heart";
};

// Rotate through the brand accent palette so each pillar feels distinct.
const accents = [
  { chip: "bg-brand-500", soft: "bg-brand-50 text-brand-600", bar: "from-brand-500 to-brand-300" },
  { chip: "bg-accent", soft: "bg-orange-50 text-accent", bar: "from-accent to-gold" },
  { chip: "bg-navy-600", soft: "bg-navy-50 text-navy-600", bar: "from-navy-600 to-sky" },
  { chip: "bg-gold", soft: "bg-gold-soft text-accent-dark", bar: "from-gold to-brand-300" },
];

const cols = pillars.length === 3 ? "md:grid-cols-3" : pillars.length === 2 ? "md:grid-cols-2" : "md:grid-cols-2 lg:grid-cols-4";
---

<section class="relative bg-white">
  <Container class="py-20 md:py-28">
    {
      (heading || intro) && (
        <div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
          {heading && <h2 class="text-3xl md:text-5xl">{heading}</h2>}
          {intro && <p class="mt-5 text-lg text-ink-soft">{intro}</p>}
        </div>
      )
    }
    <div class={`grid grid-cols-1 gap-7 ${cols}`}>
      {
        pillars.map((p, i) => {
          const accent = accents[i % accents.length];
          return (
            <div
              class="card-lift group relative overflow-hidden rounded-[var(--radius-card)] border border-navy-100 bg-white p-8 shadow-[var(--shadow-card)]"
              data-reveal
              style={`--reveal-delay: ${i * 100}ms`}
            >
              <div class={`absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r ${accent.bar}`} aria-hidden="true" />
              <span class="pointer-events-none absolute -right-2 -top-4 font-heading text-[7rem] font-extrabold leading-none text-navy-950/[0.045] transition-colors duration-300 group-hover:text-navy-950/[0.08]" aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class={`relative flex h-14 w-14 items-center justify-center rounded-2xl ${accent.soft} transition-all duration-300 group-hover:scale-110 group-hover:rotate-3`}>
                <Icon name={iconFor(p)} size={28} />
              </div>
              <h3 class="relative mt-6 text-2xl">{p.title}</h3>
              <p class="relative mt-3 leading-relaxed text-ink-soft">{p.body}</p>
            </div>
          );
        })
      }
    </div>
  </Container>
</section>
