---
import Container from "@/components/Container.astro";
import Button from "@/components/ui/Button.astro";
import Media from "@/components/Media.astro";

interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
  image?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  align?: "left" | "center";
  size?: "lg" | "md";
}
const {
  eyebrow,
  heading,
  subheading,
  image,
  ctaLabel,
  ctaHref,
  secondaryLabel,
  secondaryHref,
  align = "left",
  size = "lg",
} = Astro.props;

const pad = size === "lg" ? "py-28 md:py-40" : "py-20 md:py-28";
const alignCls = align === "center" ? "mx-auto text-center items-center" : "items-start";
---

<section class="relative overflow-hidden bg-navy-950 text-white">
  {
    image && (
      <div class="absolute inset-0">
        <Media src={image} alt="" class="h-full w-full" loading="eager" fit="cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/70 to-navy-900/35" />
        <div class="absolute inset-0 bg-gradient-to-t from-navy-950/90 via-transparent to-navy-950/40" />
      </div>
    )
  }
  {!image && <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-800 to-brand-900" />}
  <div class="absolute inset-0 bg-dots-light opacity-40" aria-hidden="true"></div>
  <!-- Soft brand glow -->
  <div class="pointer-events-none absolute -right-40 -top-40 h-[32rem] w-[32rem] rounded-full bg-brand-500/20 blur-[120px]" aria-hidden="true"></div>

  <Container class={`relative flex flex-col ${alignCls} ${pad}`}>
    <div class="max-w-3xl" data-reveal>
      {eyebrow && <p class={`eyebrow text-gold ${align === "center" ? "eyebrow-center" : ""}`}>{eyebrow}</p>}
      <h1 class="mt-4 text-4xl text-white sm:text-5xl md:text-6xl lg:text-[4.25rem]">{heading}</h1>
      <div class={`mt-6 h-1.5 w-24 rounded-full bg-gradient-to-r from-brand-500 to-gold ${align === "center" ? "mx-auto" : ""}`} aria-hidden="true"></div>
      {subheading && <p class="mt-6 max-w-2xl text-lg leading-relaxed text-navy-100 md:text-xl">{subheading}</p>}
      {
        (ctaLabel || secondaryLabel) && (
          <div class={`mt-10 flex flex-wrap gap-4 ${align === "center" ? "justify-center" : ""}`}>
            {ctaLabel && ctaHref && (
              <Button href={ctaHref} variant="brand" size="lg" arrow>
                {ctaLabel}
              </Button>
            )}
            {secondaryLabel && secondaryHref && (
              <Button href={secondaryHref} variant="white" size="lg">
                {secondaryLabel}
              </Button>
            )}
          </div>
        )
      }
    </div>
  </Container>
</section>
