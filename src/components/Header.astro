---
import { Image } from "astro:assets";
import logo from "@/assets/media/juma-logo.png";
import { nav } from "@/lib/site";
import Icon from "@/components/Icon.astro";

const path = Astro.url.pathname;
const isActive = (href: string) => href !== "#" && href !== "/" && path.startsWith(href);
---

<header id="site-header" class="sticky top-0 z-50 bg-white/90 backdrop-blur-md transition-shadow duration-300">
  <!-- Brand accent strip -->
  <div class="h-1 bg-gradient-to-r from-brand-500 via-accent to-gold" aria-hidden="true"></div>

  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3.5 sm:px-6 lg:px-8" aria-label="Primary">
    <a href="/" class="flex shrink-0 items-center transition-transform duration-300 hover:scale-[1.03]" aria-label="Juma Ventures home">
      <Image src={logo} alt="Juma Ventures" class="h-9 w-auto" loading="eager" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-0.5 lg:flex">
      {
        nav.map((item) =>
          item.children ? (
            <li class="group relative">
              <button
                class="flex items-center gap-1 rounded-md px-3 py-2 font-heading text-sm font-bold text-navy-800 transition hover:text-brand-600"
                aria-haspopup="true"
              >
                {item.label}
                <Icon name="chevronDown" size={15} class="transition duration-300 group-hover:rotate-180 group-hover:text-brand-500" />
              </button>
              <div class="invisible absolute left-0 top-full min-w-64 translate-y-2 rounded-2xl border border-navy-100 bg-white p-2 opacity-0 shadow-[var(--shadow-lift)] transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
                <ul>
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="block rounded-xl px-4 py-2.5 text-sm font-medium text-navy-700 transition hover:bg-cream hover:pl-5 hover:text-brand-600"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class:list={[
                  "relative block px-3 py-2 font-heading text-sm font-bold transition hover:text-brand-600",
                  "after:absolute after:bottom-0.5 after:left-3 after:right-3 after:h-0.5 after:origin-left after:scale-x-0 after:rounded-full after:bg-brand-500 after:transition-transform after:duration-300 hover:after:scale-x-100",
                  isActive(item.href) ? "text-brand-600 after:scale-x-100" : "text-navy-800",
                ]}
              >
                {item.label}
              </a>
            </li>
          )
        )
      }
    </ul>

    <div class="hidden items-center gap-3 lg:flex">
      <button
        data-search-open
        class="group flex items-center gap-2 rounded-full border border-navy-200 px-3.5 py-2 text-navy-500 transition hover:border-brand-300 hover:text-brand-600"
        aria-label="Search the site"
      >
        <Icon name="search" size={16} />
        <kbd class="font-heading text-[0.6rem] font-bold uppercase tracking-wider text-navy-400 transition group-hover:text-brand-500">⌘K</kbd>
      </button>
      <a
        href="/donate/"
        class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-2.5 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-600"
      >
        <Icon name="heart" size={15} />
        Donate
      </a>
    </div>

    <!-- Mobile: search + menu toggle -->
    <div class="flex items-center gap-1 lg:hidden">
      <button data-search-open class="rounded-md p-2 text-navy-800 hover:bg-navy-50" aria-label="Search the site">
        <Icon name="search" size={22} />
      </button>
      <button
        id="mobile-menu-toggle"
        class="rounded-md p-2 text-navy-800 hover:bg-navy-50"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" size={26} />
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-navy-100 bg-white lg:hidden" hidden>
    <div class="space-y-1 px-5 py-4">
      {
        nav.map((item) =>
          item.children ? (
            <details class="border-b border-navy-50 py-1">
              <summary class="flex cursor-pointer list-none items-center justify-between py-2 font-heading text-base font-bold text-navy-800">
                {item.label}
                <Icon name="chevronDown" size={18} />
              </summary>
              <ul class="pb-2 pl-3">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} class="block py-2 text-sm font-medium text-navy-700 hover:text-brand-600">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a href={item.href} class="block border-b border-navy-50 py-3 font-heading text-base font-bold text-navy-800 hover:text-brand-600">
              {item.label}
            </a>
          )
        )
      }
      <div class="pt-4">
        <a
          href="/donate/"
          class="flex w-full items-center justify-center gap-2 rounded-full bg-brand-500 px-6 py-3.5 font-heading text-sm font-bold uppercase tracking-wider text-white shadow-[var(--shadow-glow)] transition hover:bg-brand-600"
        >
          <Icon name="heart" size={16} />
          Donate
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.hasAttribute("hidden");
    if (open) {
      menu?.removeAttribute("hidden");
      menu?.classList.remove("hidden");
    } else {
      menu?.setAttribute("hidden", "");
      menu?.classList.add("hidden");
    }
    toggle.setAttribute("aria-expanded", String(!!open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });

  // Add a shadow once the page scrolls beneath the sticky header.
  const header = document.getElementById("site-header");
  const onScroll = () => header?.classList.toggle("shadow-[0_4px_24px_-8px_rgb(43_46_73/0.18)]", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
