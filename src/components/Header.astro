---
import { Image } from "astro:assets";
import logo from "@/assets/media/juma-logo.png";
import { nav } from "@/lib/site";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/Icon.astro";

const path = Astro.url.pathname;
const isActive = (href: string) => href !== "#" && href !== "/" && path.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-navy-100 bg-white/95 backdrop-blur">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3 sm:px-6 lg:px-8" aria-label="Primary">
    <a href="/" class="flex shrink-0 items-center" aria-label="Juma Ventures home">
      <Image src={logo} alt="Juma Ventures" class="h-9 w-auto" loading="eager" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 lg:flex">
      {
        nav.map((item) =>
          item.children ? (
            <li class="group relative">
              <button
                class="flex items-center gap-1 rounded-md px-3 py-2 text-sm font-semibold text-navy-800 transition hover:bg-navy-50 hover:text-brand-600"
                aria-haspopup="true"
              >
                {item.label}
                <Icon name="chevronDown" size={16} class="transition group-hover:rotate-180" />
              </button>
              <div class="invisible absolute left-0 top-full min-w-60 translate-y-1 rounded-xl border border-navy-100 bg-white p-2 opacity-0 shadow-[var(--shadow-lift)] transition-all duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
                <ul>
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="block rounded-lg px-3 py-2 text-sm text-navy-700 transition hover:bg-cream hover:text-brand-600"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class:list={[
                  "block rounded-md px-3 py-2 text-sm font-semibold transition hover:bg-navy-50 hover:text-brand-600",
                  isActive(item.href) ? "text-brand-600" : "text-navy-800",
                ]}
              >
                {item.label}
              </a>
            </li>
          )
        )
      }
    </ul>

    <div class="hidden lg:block">
      <Button href="/donate/" variant="brand" size="sm">Donate</Button>
    </div>

    <!-- Mobile toggle -->
    <button
      id="mobile-menu-toggle"
      class="rounded-md p-2 text-navy-800 hover:bg-navy-50 lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Icon name="menu" size={26} />
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-navy-100 bg-white lg:hidden" hidden>
    <div class="space-y-1 px-5 py-4">
      {
        nav.map((item) =>
          item.children ? (
            <details class="border-b border-navy-50 py-1">
              <summary class="flex cursor-pointer list-none items-center justify-between py-2 text-base font-semibold text-navy-800">
                {item.label}
                <Icon name="chevronDown" size={18} />
              </summary>
              <ul class="pb-2 pl-3">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} class="block py-2 text-sm text-navy-700 hover:text-brand-600">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a href={item.href} class="block border-b border-navy-50 py-3 text-base font-semibold text-navy-800 hover:text-brand-600">
              {item.label}
            </a>
          )
        )
      }
      <div class="pt-4">
        <Button href="/donate/" variant="brand" size="md" class="w-full">Donate</Button>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.hasAttribute("hidden");
    if (open) {
      menu?.removeAttribute("hidden");
      menu?.classList.remove("hidden");
    } else {
      menu?.setAttribute("hidden", "");
      menu?.classList.add("hidden");
    }
    toggle.setAttribute("aria-expanded", String(!!open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
</script>
