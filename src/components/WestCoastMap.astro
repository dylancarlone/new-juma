---
/**
 * Stylized dot-matrix map of the West Coast with pulsing markers for
 * Juma's four cities. The dot field is generated at build time by
 * point-in-polygon testing simplified state outlines — no map library,
 * no tiles, ~zero bytes of JS.
 *
 * Markers carry data-city; pair with elements bearing data-city-card
 * for hover sync (see homepage script).
 */
type Pt = [number, number];
const WA: Pt[] = [[140, 30], [330, 38], [326, 108], [128, 98], [132, 62]];
const OR: Pt[] = [[128, 98], [326, 108], [320, 190], [108, 178], [118, 135]];
const CA: Pt[] = [[108, 178], [320, 190], [324, 258], [252, 330], [298, 425], [286, 478], [232, 492], [196, 470], [150, 420], [122, 330], [104, 250]];

function inside(p: Pt, poly: Pt[]) {
  let ok = false;
  for (let i = 0, j = poly.length - 1; i < poly.length; j = i++) {
    const [xi, yi] = poly[i];
    const [xj, yj] = poly[j];
    if (yi > p[1] !== yj > p[1] && p[0] < ((xj - xi) * (p[1] - yi)) / (yj - yi) + xi) ok = !ok;
  }
  return ok;
}

const STEP = 13;
const dots: { x: number; y: number; state: number }[] = [];
for (let y = 24; y < 500; y += STEP) {
  for (let x = 96; x < 340; x += STEP) {
    const p: Pt = [x, y];
    if (inside(p, WA)) dots.push({ x, y, state: 0 });
    else if (inside(p, OR)) dots.push({ x, y, state: 1 });
    else if (inside(p, CA)) dots.push({ x, y, state: 2 });
  }
}

const cities = [
  { id: "seattle", name: "Seattle", x: 205, y: 62, anchor: "start", dx: 14, dy: 4 },
  { id: "sacramento", name: "Sacramento", x: 176, y: 240, anchor: "start", dx: 14, dy: 4 },
  { id: "san-francisco", name: "San Francisco", x: 132, y: 268, anchor: "end", dx: -13, dy: -6 },
  { id: "san-jose", name: "San Jose", x: 152, y: 296, anchor: "start", dx: 13, dy: 12 },
];
const stateOpacity = [0.55, 0.35, 0.55];
---

<svg viewBox="0 0 400 520" class="h-auto w-full" role="img" aria-label="Map of Juma's four West Coast cities: Seattle, Sacramento, San Francisco, and San Jose">
  <!-- dot field -->
  {dots.map((d) => <circle cx={d.x} cy={d.y} r="3" class="fill-navy-300" opacity={stateOpacity[d.state]} />)}

  <!-- connecting route -->
  <path
    d="M205,62 C150,130 195,200 176,240 M176,240 C162,250 140,256 132,268 M132,268 C138,278 146,286 152,296"
    fill="none"
    stroke="var(--color-brand-300)"
    stroke-width="2"
    stroke-dasharray="3 7"
    stroke-linecap="round"
    opacity="0.9"
  />

  <!-- city markers -->
  {
    cities.map((c, i) => (
      <a href={`/${c.id}/`} data-city={c.id} class="map-city group/city outline-none">
        <circle cx={c.x} cy={c.y} r="16" class="map-ping fill-brand-500/30" style={`animation-delay:${i * 0.5}s; transform-origin:${c.x}px ${c.y}px`} />
        <circle cx={c.x} cy={c.y} r="7.5" class="fill-brand-500 stroke-white transition-all duration-300 group-hover/city:fill-brand-600 group-focus-visible/city:fill-brand-600" stroke-width="2.5" />
        <text
          x={c.x + c.dx}
          y={c.y + c.dy}
          text-anchor={c.anchor}
          class="map-label fill-navy-900 font-heading text-[15px] font-extrabold transition-all duration-300"
          paint-order="stroke"
          stroke="#f9f1e6"
          stroke-width="4"
          stroke-linejoin="round"
        >
          {c.name}
        </text>
      </a>
    ))
  }
</svg>

<style is:global>
  @keyframes map-ping {
    0% { transform: scale(0.5); opacity: 0.9; }
    70%, 100% { transform: scale(1.8); opacity: 0; }
  }
  .map-ping { animation: map-ping 2.4s cubic-bezier(0, 0, 0.2, 1) infinite; }
  .map-city.is-active .map-label { fill: var(--color-brand-600); }
  .map-city.is-active circle:nth-of-type(2) { fill: var(--color-brand-600); r: 9; }
</style>
