---
import { site } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  noindex?: boolean;
}

const { title, description, image, type = "website", publishedTime, noindex = false } = Astro.props;

const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — Pathways to Possibility`;
const desc = description || site.description;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = image ? new URL(image, site.url).href : new URL("/og/default.png", site.url).href;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "NGO",
  name: site.name,
  url: site.url,
  description: site.description,
  foundingDate: String(site.founded),
  sameAs: [
    "https://www.facebook.com/jumaventures",
    "https://instagram.com/juma_ventures/",
    "https://www.linkedin.com/company/juma-ventures",
  ],
};
---

<title>{pageTitle}</title>
<meta name="description" content={desc} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={desc} />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} is:inline />
