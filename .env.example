# Copy to .env and fill in. All are optional for local dev (the site builds without them).

# Canonical production URL (used for SEO canonicals, sitemap, RSS).
SITE="https://juma.org"

# --- Donations -------------------------------------------------------------
# Currently points at the live GoFundMe campaign. To switch to Stripe Payment
# Links, paste your Stripe URLs here — the donate UI is identical either way.
PUBLIC_DONATE_URL="https://giving.gofundme.com/campaign/757612/donate"
PUBLIC_DONATE_MONTHLY_URL="https://giving.gofundme.com/campaign/757612/donate"

# --- Contact form (Resend) -------------------------------------------------
# Without RESEND_API_KEY, the contact form simulates success in dev and returns
# a 503 in production. Get a key at https://resend.com.
RESEND_API_KEY=""
CONTACT_TO="info@juma.org"
CONTACT_FROM="Juma Website <website@juma.org>"

# --- Newsletter (Mailchimp) ------------------------------------------------
# Defaults to the legacy Juma audience; override to point at a different list.
# PUBLIC_MAILCHIMP_URL="https://juma.us2.list-manage.com/subscribe/post?u=...&id=..."

# --- Analytics (optional; empty disables the tag) --------------------------
PUBLIC_GA4_ID=""
PUBLIC_FB_PIXEL_ID=""
