{
  "name": "new-juma",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Modern rebuild of juma.org — extracted from the legacy WordPress/Elementor site",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist/client && cp -r dist/client/pagefind .vercel/output/static/pagefind",
    "preview": "astro preview",
