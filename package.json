    "@astrojs/react": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.2",
    "marked": "^18.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.12.4",
    "tailwindcss": "^4.3.0",
    "zzfx": "^1.3.2"
  },
  "devDependencies": {
    "@fontsource/montserrat": "^5.2.8",
